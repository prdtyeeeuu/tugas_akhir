<!-- Chat Inbox Page -->
<div class="chat-inbox-wrapper">
  <div class="chat-inbox-container">
    
    <!-- Header -->
    <div class="chat-inbox-header">
      <h1>Pesan</h1>
      <% if (isApplicant) { %>
        <p>Komunikasi langsung dengan HR perusahaan</p>
      <% } else { %>
        <p>Komunikasi langsung dengan para pelamar</p>
      <% } %>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert-box alert-error">
      <%= error %>
    </div>
    <% } %>

    <!-- Conversations List -->
    <% if (typeof conversations !== 'undefined' && conversations && conversations.length > 0) { %>
      <div class="conversations-list">
        <% conversations.forEach(function(conv) { %>
        <a href="/chat/<%= conv.conversation_id %>" class="conversation-item <%= conv.unread_count > 0 ? 'unread' : '' %>">
          
          <!-- Avatar -->
          <div class="conv-avatar">
            <% if (isApplicant) { %>
              <span><%= conv.hr_name.charAt(0).toUpperCase() %></span>
            <% } else { %>
              <span><%= conv.applicant_name.charAt(0).toUpperCase() %></span>
            <% } %>
          </div>

          <!-- Info -->
          <div class="conv-info">
            <div class="conv-header">
              <h3 class="conv-name">
                <%= isApplicant ? conv.hr_name : conv.applicant_name %>
              </h3>
              <span class="conv-time">
                <%= conv.last_message_time ? formatTimeAgo(conv.last_message_time) : '' %>
              </span>
            </div>

            <div class="conv-job">
              <svg width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
                <path d="M6.5 1.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V2h2a.5.5 0 0 1 .5.5v2h1a.5.5 0 0 1 .5.5v8a.5.5 0 0 1-.5.5H3a.5.5 0 0 1-.5-.5V5.5a.5.5 0 0 1 .5-.5h1V2h2v-.5z"/>
              </svg>
              <span><%= conv.company %></span>
              <span class="job-title">- <%= conv.job_title %></span>
            </div>

            <p class="conv-last-message">
              <%= conv.last_message ? (conv.last_message.length > 50 ? conv.last_message.substring(0, 50) + '...' : conv.last_message) : 'Belum ada pesan' %>
            </p>
          </div>

          <!-- Unread Badge -->
          <% if (conv.unread_count > 0) { %>
          <div class="conv-unread">
            <span class="unread-badge"><%= conv.unread_count %></span>
          </div>
          <% } %>

        </a>
        <% }); %>
      </div>
    <% } else { %>
      <!-- Empty State -->
      <div class="chat-empty-state">
        <% if (isApplicant) { %>
          <div class="empty-icon">💬</div>
          <h3>Belum ada pesan</h3>
          <p>Mulai chat dengan HR setelah melamar pekerjaan</p>
          <div class="empty-actions">
            <a href="/jobs" class="btn-primary">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
              </svg>
              Cari Pekerjaan
            </a>
          </div>
        <% } else { %>
          <div class="empty-icon">📨</div>
          <h3>Belum ada pesan</h3>
          <p>Pelamar yang tertarik dengan lowongan Anda akan menghubungi Anda melalui sini</p>
          <div class="empty-actions">
            <a href="/hr/jobs" class="btn-primary">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/>
              </svg>
              Kelola Lowongan
            </a>
            <a href="/hr/jobs/create" class="btn-secondary">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
              </svg>
              Buat Lowongan Baru
            </a>
          </div>
        <% } %>
      </div>
    <% } %>

  </div>
</div>

<script>
  function formatTimeAgo(dateString) {
    const now = new Date();
    const date = new Date(dateString);
    const seconds = Math.floor((now - date) / 1000);

    if (seconds < 60) return 'Baru saja';
    if (seconds < 3600) return Math.floor(seconds / 60) + ' menit lalu';
    if (seconds < 86400) return Math.floor(seconds / 3600) + ' jam lalu';
    if (seconds < 604800) return Math.floor(seconds / 86400) + ' hari lalu';
    
    return date.toLocaleDateString('id-ID', { day: 'numeric', month: 'short' });
  }
</script>
