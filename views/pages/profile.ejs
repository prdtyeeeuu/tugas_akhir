<!-- Toast -->
<div id="toast" class="toast-custom fixed bottom-6 left-1/2 -translate-x-1/2 px-5 py-3 bg-slate-900 text-white text-sm font-medium rounded-xl shadow-2xl flex items-center gap-2.5">
  <span class="iconify text-brand-400 text-lg shrink-0" data-icon="lucide:info"></span>
  <span id="toast-msg">Siap!</span>
</div>

<div id="page-data" 
  data-skills='<%- JSON.stringify(parsedSkills.map(function(s){return{id:s.id,name:s.name};})) %>'
  style="display:none"></div>

<script>
  // ====== INIT: Apply banner style from data attribute ======
  document.addEventListener('DOMContentLoaded', function() {
    const banner = document.getElementById('profile-banner-preview');
    if (banner) {
      const s = banner.getAttribute('data-style');
      if (s) banner.setAttribute('style', s);
    }
  });

  // ====== TOAST ======
  let _tt;
  function showToast(msg, type='info') {
    const icons = { info:'lucide:info', success:'lucide:check-circle-2', error:'lucide:alert-circle' };
    document.querySelector('#toast .iconify').setAttribute('data-icon', icons[type]||icons.info);
    document.getElementById('toast-msg').innerText = msg;
    clearTimeout(_tt);
    document.getElementById('toast').classList.add('show');
    _tt = setTimeout(() => document.getElementById('toast').classList.remove('show'), 3500);
  }

  // ====== PREFERENCE CHECKBOXES ======
  document.querySelectorAll('.pref-checkbox').forEach(cb => {
    cb.addEventListener('change', function() {
      const tag = this.nextElementSibling;
      if (this.checked) { tag.classList.add('bg-brand-600','text-white','border-brand-600'); tag.classList.remove('bg-white','text-slate-600','border-slate-200'); }
      else { tag.classList.remove('bg-brand-600','text-white','border-brand-600'); tag.classList.add('bg-white','text-slate-600','border-slate-200'); }
    });
  });

  // ====== PROFILE DETAILS SAVE ======
  async function saveProfileDetails() {
    const bio = document.getElementById('inp-bio').value;
    const about_me = document.getElementById('inp-about').value;
    const address = document.getElementById('inp-address').value;
    const phone = document.getElementById('inp-phone').value;
    const salaryMin = document.getElementById('inp-salary-min').value;
    const salaryMax = document.getElementById('inp-salary-max').value;
    const openWorkEl = document.getElementById('inp-open-work');
    const openWork = openWorkEl ? openWorkEl.checked : false;
    const prefs = Array.from(document.querySelectorAll('.pref-checkbox:checked')).map(c => c.value);

    showToast('Menyimpan profil...');
    try {
      const res = await fetch('/profile/update-details', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bio, about_me, address, phone, expected_salary_min: salaryMin, expected_salary_max: salaryMax, open_to_work: openWork, work_preferences: JSON.stringify(prefs) })
      });
      const data = await res.json();
      if (data.success) {
        // Update UI
        document.getElementById('ui-bio').innerText = bio || 'Belum ada deskripsi singkat';
        document.getElementById('ui-about').innerText = about_me || 'Belum ada deskripsi profil.';
        document.getElementById('ui-address').innerText = address || 'Lokasi belum diatur';
        document.getElementById('ui-phone').innerText = phone || 'Nomor belum diatur';
        if (salaryMin && salaryMax) {
          const formatSal = (amount) => {
            if (!amount) return '';
            if (amount >= 1000000) return (amount / 1000000).toFixed(amount % 1000000 === 0 ? 0 : 1) + ' Jt';
            if (amount >= 1000) return (amount / 1000).toFixed(0) + ' Rb';
            return amount.toString();
          };
          document.getElementById('ui-salary').innerText = `Rp ${formatSal(salaryMin)} — ${formatSal(salaryMax)}`;
        }
        // Open to work
        const badge = document.getElementById('ui-open-badge');
        badge.classList.toggle('hidden', !openWork);
        // Prefs
        const prefsEl = document.getElementById('ui-work-prefs-container');
        prefsEl.innerHTML = prefs.map(p => `<span class="px-3 py-1 bg-brand-50 text-brand-600 border border-brand-100 text-xs font-medium rounded-lg">${p}</span>`).join('');
        document.getElementById('modal-edit-profile').classList.remove('active');
        showToast('Profil berhasil disimpan!', 'success');
      } else { showToast(data.error || 'Gagal menyimpan', 'error'); }
    } catch(e) { showToast('Koneksi gagal ke server', 'error'); }
  }

  // ====== SKILLS ======
  let currentSkills = JSON.parse(document.getElementById('page-data').dataset.skills || '[]');

  function openSkillModal() {
    renderSkillChips();
    document.getElementById('modal-edit-skills').classList.add('active');
    setTimeout(() => document.getElementById('inp-new-skill').focus(), 100);
  }

  function renderSkillChips() {
    const c = document.getElementById('modal-skill-chips');
    c.innerHTML = currentSkills.length === 0
      ? '<p class="text-slate-400 text-xs italic">Belum ada keahlian. Tambahkan di atas.</p>'
      : currentSkills.map(s => `<div class="skill-tag">${s.name}<span class="del-btn" onclick="deleteSkill(${s.id||'null'},'${s.name}',this)">×</span></div>`).join('');
  }

  document.getElementById('skill-add-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const val = document.getElementById('inp-new-skill').value.trim();
    if (!val) return;
    if (currentSkills.find(s => s.name.toLowerCase() === val.toLowerCase())) { showToast('Sudah ada!', 'error'); return; }
    try {
      const res = await fetch('/profile/skills/add', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({name:val}) });
      const data = await res.json();
      if (data.success) {
        currentSkills.push({ id: data.id||null, name: val });
        document.getElementById('inp-new-skill').value = '';
        renderSkillChips();
        updateSkillListUI();
      } else showToast(data.error||'Gagal', 'error');
    } catch(e) { showToast('Koneksi gagal','error'); }
  });

  async function deleteSkill(id, name, el) {
    try {
      if (id) {
        const res = await fetch(`/profile/skills/remove/${id}`, { method:'DELETE' });
        const data = await res.json();
        if (!data.success) { showToast('Gagal hapus','error'); return; }
      }
      currentSkills = currentSkills.filter(s => s.name !== name);
      renderSkillChips();
      updateSkillListUI();
    } catch(e) { showToast('Koneksi gagal','error'); }
  }

  function updateSkillListUI() {
    const c = document.getElementById('ui-skill-list');
    c.innerHTML = currentSkills.length === 0
      ? '<p class="text-slate-400 text-xs italic">Belum ada keahlian. Klik Edit untuk menambah.</p>'
      : currentSkills.map(s => `<span class="px-4 py-1.5 bg-white border border-slate-200 text-brand-600 text-xs font-medium rounded-full shadow-sm">${s.name}</span>`).join('');
  }

  // ====== EXPERIENCE ======
  async function submitExperience() {
    const position = document.getElementById('exp-position').value.trim();
    const company = document.getElementById('exp-company').value.trim();
    if (!position || !company) { showToast('Posisi dan perusahaan wajib diisi','error'); return; }
    const start_date = document.getElementById('exp-start').value;
    const end_date = document.getElementById('exp-end').value;
    const is_current = document.getElementById('exp-current').checked;
    const description = document.getElementById('exp-desc').value;
    try {
      const res = await fetch('/profile/experiences/add', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({position,company,start_date,end_date,is_current,description}) });
      const data = await res.json();
      if (data.success) {
        document.getElementById('modal-add-exp').classList.remove('active');
        showToast('Pengalaman berhasil ditambahkan!','success');
        setTimeout(() => location.reload(), 800);
      } else showToast(data.error||'Gagal','error');
    } catch(e) { showToast('Koneksi gagal','error'); }
  }

  async function deleteExperience(id, btn) {
    const ok = await lokerinConfirm('Hapus pengalaman kerja ini dari profil Anda?', {
      title: 'Hapus Pengalaman', confirmText: 'Ya, Hapus', cancelText: 'Batal', danger: true
    });
    if (!ok) return;
    try {
      const res = await fetch(`/profile/experiences/remove/${id}`, { method:'DELETE' });
      const data = await res.json();
      if (data.success) { btn.closest('[data-exp-id]').remove(); showToast('Pengalaman dihapus','success'); }
      else showToast(data.error||'Gagal','error');
    } catch(e) { showToast('Koneksi gagal','error'); }
  }

  // ====== EDUCATION ======
  async function submitEducation() {
    const school = document.getElementById('edu-school').value.trim();
    if (!school) { showToast('Nama institusi wajib diisi','error'); return; }
    const degree = document.getElementById('edu-degree').value;
    const field_of_study = document.getElementById('edu-field').value;
    const start_year = document.getElementById('edu-start').value;
    const end_year = document.getElementById('edu-end').value;
    const gpa = document.getElementById('edu-gpa').value;
    try {
      const res = await fetch('/profile/educations/add', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({school,degree,field_of_study,start_year,end_year,gpa}) });
      const data = await res.json();
      if (data.success) {
        document.getElementById('modal-add-edu').classList.remove('active');
        showToast('Pendidikan berhasil ditambahkan!','success');
        setTimeout(() => location.reload(), 800);
      } else showToast(data.error||'Gagal','error');
    } catch(e) { showToast('Koneksi gagal','error'); }
  }

  async function deleteEducation(id, btn) {
    const ok = await lokerinConfirm('Hapus riwayat pendidikan ini dari profil Anda?', {
      title: 'Hapus Pendidikan', confirmText: 'Ya, Hapus', cancelText: 'Batal', danger: true
    });
    if (!ok) return;
    try {
      const res = await fetch(`/profile/educations/remove/${id}`, { method:'DELETE' });
      const data = await res.json();
      if (data.success) { btn.closest('[data-edu-id]').remove(); showToast('Pendidikan dihapus','success'); }
      else showToast(data.error||'Gagal','error');
    } catch(e) { showToast('Koneksi gagal','error'); }
  }

  // ====== AVATAR UPLOAD ======
  document.getElementById('profile-file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    showToast('Mengunggah foto profil...');
    const reader = new FileReader();
    reader.onload = e2 => document.getElementById('avatar-preview').src = e2.target.result;
    reader.readAsDataURL(file);
    const fd = new FormData(); fd.append('profileImage', file);
    fetch('/profile/upload-image', { method:'POST', body:fd })
      .then(r => r.json()).then(d => {
        if (d.success) { showToast('Foto profil diperbarui!','success'); setTimeout(() => location.href='/profile?t='+Date.now(), 800); }
        else showToast(d.error||'Gagal upload','error');
      }).catch(() => showToast('Koneksi gagal','error'));
  });

  async function removeAvatar() {
    const ok = await lokerinConfirm('Foto profil Anda akan dihapus.', {
      title: 'Hapus Foto Profil', confirmText: 'Ya, Hapus', cancelText: 'Batal', danger: true
    });
    if (!ok) return;
    const res = await fetch('/profile/remove-image', { method:'POST' });
    showToast('Foto dihapus','success');
    setTimeout(() => location.href='/profile?t='+Date.now(), 600);
  }

  // ====== BANNER UPLOAD ======
  document.getElementById('banner-file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    showToast('Mengunggah banner...');
    const reader = new FileReader();
    reader.onload = e2 => { const b = document.getElementById('profile-banner-preview'); b.style.backgroundImage = `url('${e2.target.result}')`; b.style.backgroundSize='cover'; b.style.backgroundPosition='center'; };
    reader.readAsDataURL(file);
    const fd = new FormData(); fd.append('bannerImage', file);
    fetch('/profile/upload-banner', { method:'POST', body:fd })
      .then(r => r.json()).then(d => {
        if (d.success) { showToast('Banner diperbarui!','success'); setTimeout(() => location.href='/profile?v='+Date.now(), 800); }
        else showToast(d.error||'Gagal upload','error');
      }).catch(() => showToast('Koneksi gagal','error'));
  });

  async function removeBanner() {
    // Use native confirm if lokerinConfirm not available
    let ok = false;
    if (typeof lokerinConfirm === 'function') {
      ok = await lokerinConfirm('Banner profil Anda akan dihapus.', {
        title: 'Hapus Banner', confirmText: 'Ya, Hapus', cancelText: 'Batal', danger: true
      });
    } else {
      ok = confirm('Banner profil Anda akan dihapus. Lanjutkan?');
    }
    if (!ok) return;

    // Visually reset immediately
    const banner = document.getElementById('profile-banner-preview');
    banner.style.backgroundImage = '';
    banner.style.background = '';
    banner.className = banner.className.replace(/banner-gradient-\S+/g, '').trim() + ' banner-gradient-2';

    try {
      await fetch('/profile/remove-banner', { method: 'POST' });
      // Reload page to reflect changes
      setTimeout(() => { window.location.href = '/profile?v=' + Date.now(); }, 300);
    } catch (err) {
      alert('Gagal menghapus banner. Silakan coba lagi.');
      // Revert visual change on failure
      window.location.reload();
    }
  }

  // ====== BANNER GRADIENT ======
  // ====== PORTFOLIO ======
  function previewPortfolioImage(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.getElementById('portfolio-img-preview');
      img.src = e.target.result;
      img.style.display = 'block';
      document.getElementById('portfolio-img-placeholder').style.display = 'none';
      document.getElementById('portfolio-img-clear').classList.remove('hidden');
    };
    reader.readAsDataURL(file);
  }

  function clearPortfolioImage() {
    document.getElementById('portfolio-img-input').value = '';
    document.getElementById('portfolio-img-preview').style.display = 'none';
    document.getElementById('portfolio-img-preview').src = '';
    document.getElementById('portfolio-img-placeholder').style.display = 'flex';
    document.getElementById('portfolio-img-clear').classList.add('hidden');
  }

  function closePortfolioModal() {
    document.getElementById('modal-add-portfolio').classList.remove('active');
    // Reset form
    document.getElementById('pf-title').value = '';
    document.getElementById('pf-desc').value = '';
    document.getElementById('pf-url').value = '';
    document.getElementById('pf-github').value = '';
    clearPortfolioImage();
  }

  async function submitPortfolio() {
    const title = document.getElementById('pf-title').value.trim();
    if (!title) { showToast('Judul proyek wajib diisi', 'error'); return; }

    const description = document.getElementById('pf-desc').value;
    const url = document.getElementById('pf-url').value;
    const github_url = document.getElementById('pf-github').value;
    const imgInput = document.getElementById('portfolio-img-input');

    const fd = new FormData();
    fd.append('title', title);
    fd.append('description', description);
    fd.append('url', url);
    fd.append('github_url', github_url);
    if (imgInput.files[0]) {
      fd.append('portfolioImage', imgInput.files[0]);
    }

    showToast('Menyimpan portofolio...');
    try {
      const res = await fetch('/portfolios/add', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        closePortfolioModal();
        showToast('Portofolio berhasil ditambahkan!', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        showToast(data.error || 'Gagal menyimpan', 'error');
      }
    } catch(e) { showToast('Koneksi gagal', 'error'); }
  }

  async function deletePortfolio(id, btn) {
    const ok = await lokerinConfirm('Portofolio ini akan dihapus dari profil Anda.', {
      title: 'Hapus Portofolio', confirmText: 'Ya, Hapus', cancelText: 'Batal', danger: true
    });
    if (!ok) return;
    try {
      const res = await fetch(`/portfolios/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) {
        btn.closest('[data-portfolio-id]').remove();
        showToast('Portofolio dihapus', 'success');
        // Show empty message if no items left
        const grid = document.getElementById('ui-portfolios-list');
        if (grid && grid.children.length === 0) {
          grid.innerHTML = '<div class="col-span-2"><p class="text-slate-400 text-xs italic">Belum ada portofolio. Klik Tambah untuk mengunggah proyek Anda.</p></div>';
        }
      } else showToast(data.error || 'Gagal', 'error');
    } catch(e) { showToast('Koneksi gagal', 'error'); }
  }

  async function setBannerGradient(gradient) {
    // Immediately update banner visuals (no refresh needed)
    const banner = document.getElementById('profile-banner-preview');
    banner.setAttribute('style', 'background:' + gradient + ';');
    banner.className = banner.className.replace(/banner-gradient-\S+/g, '').trim();

    // Close modal instantly
    document.getElementById('modal-banner-color').classList.remove('active');
    showToast('Menerapkan warna...', 'info');

    // Save first solid hex color to DB (for persistence)
    const firstColor = gradient.match(/#[0-9a-fA-F]{6}/)?.[0] || '#2563EB';
    try {
      const res = await fetch('/profile/set-banner-color', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ color: firstColor })
      });
      const d = await res.json();
      if (d.success) showToast('Warna banner disimpan!', 'success');
      else showToast(d.error || 'Gagal menyimpan', 'error');
    } catch(e) { showToast('Koneksi gagal', 'error'); }
  }
</script>
