<!-- Profile Page - Redesigned -->
<link rel="stylesheet" href="/css/profile-new.css">

<div class="profile-new-wrapper">
  <!-- Profile Card -->
  <div class="profile-card">

    <!-- Banner -->
    <div class="profile-banner" id="profile-banner" style="<%= typeof user !== 'undefined' && user.banner_image ? 'background-image: url(/images/banners/' + user.banner_image + ');' : '' %><%= typeof user !== 'undefined' && user.banner_color && !user.banner_image ? 'background-color: ' + user.banner_color + ';' : '' %>">
      <div class="banner-actions">
        <div class="dropdown" id="banner-dropdown">
          <button type="button" class="btn-icon" onclick="toggleDropdown('banner-dropdown')">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
            </svg>
          </button>
          <div class="dropdown-menu hidden" id="banner-menu">
            <label for="banner-file-input" class="dropdown-item">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
              </svg>
              <%= typeof user !== 'undefined' && user.banner_image ? 'Ganti Banner' : 'Upload Banner' %>
            </label>
            <% if (typeof bannerColors !== 'undefined') { %>
            <div class="dropdown-divider"></div>
            <div class="color-grid">
              <% bannerColors.forEach(function(color) { %>
                <button type="button" onclick="selectBannerColor('<%= color.value %>')" class="color-swatch <%= typeof user !== 'undefined' && user.banner_color === color.value && !user.banner_image ? 'active' : '' %>" style="background-color: <%= color.value %>;" title="<%= color.label %>"></button>
              <% }); %>
            </div>
            <% } %>
            <% if (typeof user !== 'undefined' && (user.banner_image || user.banner_color)) { %>
            <div class="dropdown-divider"></div>
            <form action="/profile/remove-banner" method="POST" style="padding: 0;">
              <button type="submit" class="dropdown-item text-danger">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                  <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H14a1 1 0 0 1 1 1v1zM4 14V4h8v10H4z"/>
                </svg>
                Hapus Banner
              </button>
            </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Avatar & Header -->
    <div class="profile-header-section">
      <div class="avatar-wrapper">
        <% if (typeof user !== 'undefined' && user.profile_image) { %>
          <img src="/images/profiles/<%= user.profile_image %>" alt="Profile" class="profile-avatar">
        <% } else { %>
          <div class="profile-avatar" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 700;">
            <%= typeof user !== 'undefined' ? user.name.charAt(0).toUpperCase() : 'U' %>
          </div>
        <% } %>
        <label for="profile-file-input" class="avatar-edit" title="Ganti foto">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5v.5a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-.5a.5.5 0 0 1 .146-.354z"/>
          </svg>
        </label>
      </div>

      <div class="header-info">
        <div class="name-row">
          <h1 class="user-name"><%= typeof user !== 'undefined' ? user.name : 'User' %></h1>
          <% if (typeof user !== 'undefined' && user.role === 'hr') { %>
          <span class="verified-badge" title="HR Verified">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm3.293 5.293a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-2-2a.5.5 0 1 1 .708-.708L7.5 8.793l3.293-3.293z"/>
            </svg>
          </span>
          <% } %>
        </div>
        <p class="user-email"><%= typeof user !== 'undefined' ? user.email : '' %></p>
      </div>

      <button type="button" class="btn-edit" onclick="toggleEditMode()">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5v.5a.5.5 0 0 1-.5.5H4a.5.5 0 0 1-.5-.5v-.5a.5.5 0 0 1 .146-.354z"/>
        </svg>
        Edit Profil
      </button>
    </div>

    <!-- Main Content -->
    <div class="profile-content">

      <!-- Alert Messages -->
      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
        </svg>
        <%= success %>
      </div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
        </svg>
        <%= error %>
      </div>
      <% } %>

      <!-- Sidebar: Contact Info -->
      <aside class="profile-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">Kontak</h3>
          <div class="contact-list">
            <div class="contact-item">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/>
              </svg>
              <span><%= typeof user !== 'undefined' ? user.email : '' %></span>
            </div>
            <% if (typeof user !== 'undefined' && user.phone) { %>
            <div class="contact-item">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/>
              </svg>
              <span><%= user.phone %></span>
            </div>
            <% } %>
          </div>
        </div>

        <% if (typeof profile !== 'undefined' && profile && profile.location) { %>
        <div class="sidebar-section">
          <h3 class="sidebar-title">Lokasi</h3>
          <div class="contact-item">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
            </svg>
            <span><%= profile.location %></span>
          </div>
        </div>
        <% } %>

        <div class="sidebar-section">
          <h3 class="sidebar-title">Sosial Media</h3>
          <div class="social-links">
            <% if (typeof profile !== 'undefined' && profile && profile.linkedin) { %>
            <a href="<%= profile.linkedin %>" target="_blank" class="social-link">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
              </svg>
              LinkedIn
            </a>
            <% } %>
            <% if (typeof profile !== 'undefined' && profile && profile.github) { %>
            <a href="<%= profile.github %>" target="_blank" class="social-link">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              GitHub
            </a>
            <% } %>
          </div>
        </div>
      </aside>

      <!-- Main Sections -->
      <main class="profile-main">
        <!-- Tentang Saya -->
        <section class="profile-section">
          <h2 class="section-title">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
            </svg>
            Tentang Saya
          </h2>
          <textarea id="bio-textarea" name="bio" class="bio-textarea" placeholder="Ceritakan tentang diri Anda..." rows="4"><%= typeof user !== 'undefined' && user.bio ? user.bio : '' %></textarea>
        </section>

        <!-- Keahlian / Skills -->
        <section class="profile-section">
          <h2 class="section-title">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
              <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
            </svg>
            Keahlian
          </h2>
          <div class="skills-container">
            <% if (typeof skills !== 'undefined' && skills && skills.length > 0) { %>
              <% skills.forEach(function(skill) { %>
              <span class="skill-tag">
                <%= skill.name %>
                <button type="button" class="skill-remove" onclick="removeSkill(<%= skill.id %>)">×</button>
              </span>
              <% }); %>
            <% } %>
            <input type="text" id="skill-input" class="skill-input" placeholder="Tekan Enter untuk tambah keahlian..." onkeypress="handleSkillInput(event)">
          </div>
        </section>

        <!-- Portfolio -->
        <section class="profile-section">
          <h2 class="section-title">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
              <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/>
            </svg>
            Portofolio & Proyek
          </h2>
          <div class="portfolio-grid">
            <label for="portfolio-upload" class="portfolio-card upload-card">
              <svg width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
              </svg>
              <span>Upload Proyek</span>
            </label>
            <% if (typeof portfolios !== 'undefined' && portfolios && portfolios.length > 0) { %>
              <% portfolios.forEach(function(portfolio) { %>
              <div class="portfolio-card">
                <% if (portfolio.image_url) { %>
                <img src="<%= portfolio.image_url %>" alt="<%= portfolio.title %>" class="portfolio-image">
                <% } else { %>
                <div class="portfolio-placeholder">
                  <svg width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                    <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
                  </svg>
                </div>
                <% } %>
                <div class="portfolio-info">
                  <h4 class="portfolio-title"><%= portfolio.title %></h4>
                  <p class="portfolio-desc"><%= portfolio.description ? portfolio.description.substring(0, 60) + '...' : '' %></p>
                  <div class="portfolio-actions">
                    <% if (portfolio.url) { %>
                    <a href="<%= portfolio.url %>" target="_blank" class="portfolio-link">Live Demo</a>
                    <% } %>
                    <% if (portfolio.github_url) { %>
                    <a href="<%= portfolio.github_url %>" target="_blank" class="portfolio-link">GitHub</a>
                    <% } %>
                  </div>
                </div>
              </div>
              <% }); %>
            <% } %>
          </div>
        </section>

        <!-- Submit Button -->
        <div class="profile-actions">
          <button type="submit" class="btn-save" onclick="saveProfile()">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
            </svg>
            Simpan Perubahan
          </button>
        </div>
      </main>
    </div>
  </div>
</div>

<!-- Hidden Forms -->
<form id="banner-upload-form" enctype="multipart/form-data" style="display: none;">
  <input type="file" name="bannerImage" id="banner-file-input" accept="image/*">
</form>
<form id="profile-upload-form" enctype="multipart/form-data" style="display: none;">
  <input type="file" name="profileImage" id="profile-file-input" accept="image/*">
</form>
<form id="portfolio-upload-form" enctype="multipart/form-data" style="display: none;">
  <input type="file" name="portfolioImage" id="portfolio-upload" accept="image/*">
</form>

<script>
  // Toggle dropdown
  function toggleDropdown(id) {
    const menu = document.getElementById(id.replace('dropdown', 'menu'));
    menu.classList.toggle('hidden');
  }

  // Toggle edit mode (for compatibility)
  function toggleEditMode() {
    // Scroll to top or show edit mode
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Save profile
  async function saveProfile() {
    const bio = document.getElementById('bio-textarea').value;

    try {
      const response = await fetch('/profile/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bio })
      });

      if (response.ok) {
        alert('Profil berhasil disimpan!');
        location.reload();
      } else {
        alert('Gagal menyimpan profil');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Terjadi kesalahan');
    }
  }

  // Handle skill input
  async function handleSkillInput(event) {
    if (event.key === 'Enter') {
      const input = event.target;
      const skillName = input.value.trim();

      if (!skillName) return;

      try {
        const response = await fetch('/profile/skills', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: skillName })
        });

        if (response.ok) {
          location.reload();
        } else {
          alert('Gagal menambah keahlian');
        }
      } catch (error) {
        console.error('Error:', error);
      }
    }
  }

  // Remove skill
  async function removeSkill(skillId) {
    if (!confirm('Hapus keahlian ini?')) return;

    try {
      const response = await fetch(`/profile/skills/${skillId}`, {
        method: 'DELETE'
      });

      if (response.ok) {
        location.reload();
      } else {
        alert('Gagal menghapus keahlian');
      }
    } catch (error) {
      console.error('Error:', error);
    }
  }

  // Close dropdown when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.dropdown')) {
      document.querySelectorAll('.dropdown-menu').forEach(menu => {
        menu.classList.add('hidden');
      });
    }
  });

  // Handle profile image upload
  document.getElementById('profile-file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;

    const formData = new FormData();
    formData.append('profileImage', file);

    fetch('/profile/upload-image', {
      method: 'POST',
      body: formData
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        location.reload();
      } else {
        alert(data.error || 'Gagal upload foto profil');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Terjadi kesalahan saat upload');
    });
  });

  // Handle banner image upload
  document.getElementById('banner-file-input').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;

    const formData = new FormData();
    formData.append('bannerImage', file);

    // Tampilkan preview langsung
    const reader = new FileReader();
    reader.onload = function(e) {
      const banner = document.getElementById('profile-banner');
      banner.style.backgroundImage = `url(${e.target.result})`;
    };
    reader.readAsDataURL(file);

    fetch('/profile/upload-banner', {
      method: 'POST',
      body: formData
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // Update banner dengan timestamp untuk force reload
        const banner = document.getElementById('profile-banner');
        banner.style.backgroundImage = `url('/images/banners/${data.banner_image}?t=${Date.now()}')`;
        // Hapus background color jika ada
        banner.style.backgroundColor = '';
      } else {
        alert(data.error || 'Gagal upload banner');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Terjadi kesalahan saat upload');
    });
  });

  // Handle banner color selection
  async function selectBannerColor(color) {
    try {
      const response = await fetch('/profile/set-banner-color', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ color })
      });

      const data = await response.json();

      if (data.success) {
        location.reload();
      } else {
        alert(data.error || 'Gagal mengubah warna banner');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Terjadi kesalahan');
    }
  }
</script>
