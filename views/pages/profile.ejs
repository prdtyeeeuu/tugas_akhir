<style>
:root {
  --brand-50: #EFF6FF; --brand-100: #DBEAFE; --brand-200: #BFDBFE;
  --brand-500: #3B82F6; --brand-600: #2563EB; --brand-700: #1D4ED8;
}
/* Brand color utilities */
.bg-brand-50 { background-color: #EFF6FF !important; }
.bg-brand-100 { background-color: #DBEAFE !important; }
.bg-brand-500 { background-color: #3B82F6 !important; }
.bg-brand-600 { background-color: #2563EB !important; }
.bg-brand-700 { background-color: #1D4ED8 !important; }
.hover\:bg-brand-50:hover { background-color: #EFF6FF !important; }
.hover\:bg-brand-100:hover { background-color: #DBEAFE !important; }
.hover\:bg-brand-700:hover { background-color: #1D4ED8 !important; }
.text-brand-500 { color: #3B82F6 !important; }
.text-brand-600 { color: #2563EB !important; }
.text-brand-700 { color: #1D4ED8 !important; }
.hover\:text-brand-600:hover { color: #2563EB !important; }
.hover\:text-brand-700:hover { color: #1D4ED8 !important; }
.border-brand-100 { border-color: #DBEAFE !important; }
.border-brand-500 { border-color: #3B82F6 !important; }
.border-brand-600 { border-color: #2563EB !important; }
.ring-brand-500 { --tw-ring-color: #3B82F6; }
.focus\:ring-brand-500:focus { box-shadow: 0 0 0 2px #3B82F6 !important; }
/* Toast & Modal */
.toast-custom { transform: translateY(100px); opacity: 0; transition: all 0.4s cubic-bezier(0.16,1,0.3,1); z-index:100; pointer-events:none; }
.toast-custom.show { transform: translateY(0); opacity: 1; }
.modal-overlay { opacity:0; visibility:hidden; transition:all 0.2s ease; backdrop-filter:blur(2px); }
.modal-overlay.active { opacity:1; visibility:visible; }
.modal-container { transform:scale(0.95); transition:all 0.2s ease; }
.modal-overlay.active .modal-container { transform:scale(1); }
/* Banner gradients */
.banner-gradient-1 { background: linear-gradient(135deg, #667eea, #764ba2); }
.banner-gradient-2 { background: linear-gradient(135deg, #2563EB, #06b6d4); }
.banner-gradient-3 { background: linear-gradient(135deg, #f093fb, #f5576c); }
.banner-gradient-4 { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.banner-gradient-5 { background: linear-gradient(135deg, #43e97b, #38f9d7); }
.banner-gradient-6 { background: linear-gradient(135deg, #fa709a, #fee140); }
.banner-gradient-7 { background: linear-gradient(135deg, #30cfd0, #330867); }
.banner-gradient-8 { background: linear-gradient(135deg, #ff9a9e, #fecfef); }
/* Skill tags */
.skill-tag { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; background:#fff; border:1px solid #e2e8f0; border-radius:9999px; font-size:12px; font-weight:500; color:#374151; }
.skill-tag .del-btn { color:#94a3b8; cursor:pointer; font-size:14px; line-height:1; }
.skill-tag .del-btn:hover { color:#ef4444; }
/* Portfolio cards */
.portfolio-card { position:relative; background:#fff; border:1px solid #e2e8f0; border-radius:16px; overflow:hidden; transition:box-shadow 0.2s, transform 0.2s; }
.portfolio-card:hover { box-shadow:0 8px 24px rgba(37,99,235,0.1); transform:translateY(-2px); }
.portfolio-card .card-img { width:100%; height:150px; object-fit:cover; background:#f1f5f9; }
.portfolio-card .card-img-placeholder { width:100%; height:150px; background:linear-gradient(135deg,#EFF6FF,#DBEAFE); display:flex; align-items:center; justify-content:center; }
.portfolio-card .del-overlay { position:absolute; top:8px; right:8px; opacity:0; transition:opacity 0.2s; }
.portfolio-card:hover .del-overlay { opacity:1; }
/* Portfolio image upload preview */
#portfolio-img-preview { width:100%; height:140px; object-fit:cover; border-radius:10px; display:none; }
#portfolio-img-placeholder { width:100%; height:140px; border:2px dashed #e2e8f0; border-radius:10px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; cursor:pointer; transition:all 0.2s; }
#portfolio-img-placeholder:hover { border-color:#3B82F6; background:#EFF6FF; }
</style>
<script src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>

<%
  // Parse stored data safely
  let parsedSkills = [];
  let parsedExperiences = experiences || [];
  let parsedEducations = educations || [];
  let openToWork = true;
  let workPrefs = ['Remote','Full-time'];
  let salaryMin = user.expected_salary_min || '';
  let salaryMax = user.expected_salary_max || '';
  // HR tidak tampilkan badge "terbuka untuk kerja"
  if (user.role === 'hr') {
    openToWork = false;
  } else {
    if (user.open_to_work !== undefined) openToWork = user.open_to_work == 1;
  }
  try { if (user.work_preferences) workPrefs = JSON.parse(user.work_preferences); } catch(e){}
  parsedSkills = skills || [];

  function formatSalary(amount) {
    if (!amount) return '';
    if (amount >= 1000000) {
      return (amount / 1000000).toFixed(amount % 1000000 === 0 ? 0 : 1) + ' Jt';
    } else if (amount >= 1000) {
      return (amount / 1000).toFixed(0) + ' Rb';
    }
    return amount.toString();
  }
%>

<!-- Hidden Upload Forms -->
<form id="banner-upload-form" enctype="multipart/form-data" style="position:absolute;width:1px;height:1px;overflow:hidden;opacity:0;z-index:-1;">
  <input type="file" name="bannerImage" id="banner-file-input" accept="image/*">
</form>
<form id="profile-upload-form" enctype="multipart/form-data" style="position:absolute;width:1px;height:1px;overflow:hidden;opacity:0;z-index:-1;">
  <input type="file" name="profileImage" id="profile-file-input" accept="image/*">
</form>

<div class="pt-8 pb-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto w-full">

  <!-- SUCCESS/ERROR FLASH -->
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm flex items-center gap-2">
    <span class="iconify" data-icon="lucide:check-circle-2"></span> <%= success %>
  </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm flex items-center gap-2">
    <span class="iconify" data-icon="lucide:alert-circle"></span> <%= error %>
  </div>
  <% } %>

  <!-- PROFILE HEADER CARD -->
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-6">
    <!-- Banner -->
    <%
      let bannerStyle = '';
      let bannerClass = 'banner-gradient-2';
      if (user.banner_image) {
        bannerStyle = `background-image:url('/images/banners/${user.banner_image}?t=${Date.now()}');background-size:cover;background-position:center;`;
        bannerClass = '';
      } else if (user.banner_color) {
        bannerStyle = `background:${user.banner_color};`;
        bannerClass = '';
      }
    %>
    <div id="profile-banner-preview" class="h-44 sm:h-56 relative <%- bannerClass %>" data-style="<%- bannerStyle %>">
      <!-- Banner Controls -->
      <div class="absolute top-3 right-3 flex gap-2 z-10">
        <button onclick="document.getElementById('banner-file-input').click();" class="px-2.5 py-1.5 bg-white/25 backdrop-blur-sm text-white text-xs font-semibold rounded-lg hover:bg-white/40 transition-all">
          <span class="iconify inline -mt-0.5" data-icon="lucide:camera"></span> Ubah Foto
        </button>
        <button onclick="document.getElementById('modal-banner-color').classList.add('active')" class="px-2.5 py-1.5 bg-white/25 backdrop-blur-sm text-white text-xs font-semibold rounded-lg hover:bg-white/40 transition-all">
          <span class="iconify inline -mt-0.5" data-icon="lucide:palette"></span> Warna
        </button>
        <% if (user.banner_image || user.banner_color) { %>
        <button type="button" onclick="removeBanner()" class="px-2.5 py-1.5 bg-red-500/80 backdrop-blur-sm text-white text-xs font-semibold rounded-lg hover:bg-red-600 transition-all" title="Hapus Banner">
          <span class="iconify inline -mt-0.5" data-icon="lucide:trash-2"></span> Hapus
        </button>
        <% } %>
      </div>
    </div>

    <!-- Info -->
    <div class="px-5 sm:px-8 pb-6">
      <div class="flex flex-col sm:flex-row gap-5 -mt-16 sm:-mt-20">
        <!-- Avatar -->
        <div class="relative group shrink-0">
          <div class="w-32 h-32 sm:w-44 sm:h-44 rounded-2xl border-4 border-white bg-slate-100 overflow-hidden shadow-md">
            <img id="avatar-preview"
              src="<%= user.profile_image ? '/images/profiles/' + user.profile_image + '?t=' + Date.now() : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.name) + '&background=DBEAFE&color=1D4ED8&size=200' %>"
              alt="Avatar" class="w-full h-full object-cover">
          </div>
          <button type="button" onclick="document.getElementById('profile-file-input').click();" class="absolute inset-0 rounded-2xl bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer z-10">
            <span class="iconify text-white text-2xl" data-icon="lucide:camera"></span>
          </button>
          <% if (user.profile_image) { %>
          <button onclick="removeAvatar()" title="Hapus foto" class="absolute -top-1 -right-1 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center z-20 hover:bg-red-600 transition-colors">
            <span class="iconify text-xs" data-icon="lucide:x"></span>
          </button>
          <% } %>
        </div>

        <!-- Details -->
        <div class="flex-1 mt-16 sm:mt-20 pt-1">
          <div class="flex flex-col md:flex-row md:items-start justify-between gap-3">
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight"><%= user.name %></h1>
              <p class="text-slate-500 text-sm mt-1" id="ui-bio"><%= user.bio || 'Belum ada deskripsi singkat' %></p>
              <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-slate-500">
                <span class="flex items-center gap-1.5">
                  <span class="iconify text-brand-500" data-icon="lucide:map-pin"></span>
                  <span id="ui-address"><%= user.address || 'Lokasi belum diatur' %></span>
                </span>
                <span class="flex items-center gap-1.5">
                  <span class="iconify text-brand-500" data-icon="lucide:mail"></span>
                  <%= user.email %>
                </span>
                <span class="flex items-center gap-1.5">
                  <span class="iconify text-brand-500" data-icon="lucide:phone"></span>
                  <span id="ui-phone"><%= user.phone || 'Nomor belum diatur' %></span>
                </span>
              </div>
            </div>
            <% if (openToWork) { %>
            <span id="ui-open-badge" class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 text-green-600 text-xs font-semibold border border-green-100 rounded-full">
              <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span> Terbuka untuk kerja
            </span>
            <% } else { %>
            <span id="ui-open-badge" class="shrink-0 hidden inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 text-green-600 text-xs font-semibold border border-green-100 rounded-full">
              <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span> Terbuka untuk kerja
            </span>
            <% } %>
          </div>
          <!-- Buttons -->
          <div class="mt-5 flex flex-wrap gap-3">
            <button onclick="document.getElementById('modal-edit-profile').classList.add('active')" class="inline-flex items-center gap-2 px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg transition-all shadow-sm">
              <span class="iconify" data-icon="lucide:pencil"></span> Edit Profil
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <!-- LEFT COLUMN -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Tentang Saya -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-base font-bold text-slate-900 mb-3">Tentang Saya</h2>
        <p class="text-slate-600 leading-relaxed text-sm" id="ui-about"><%= user.about_me || 'Belum ada deskripsi profil.' %></p>
        <div class="mt-4 flex flex-wrap gap-2" id="ui-work-prefs-container">
          <% workPrefs.forEach(function(pref) { %>
          <span class="px-3 py-1 bg-brand-50 text-brand-600 border border-brand-100 text-xs font-medium rounded-lg"><%= pref %></span>
          <% }); %>
        </div>
      </div>

      <!-- Keahlian -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6 relative">
        <button onclick="openSkillModal()" class="absolute top-5 right-5 text-xs text-brand-600 hover:underline font-semibold">Edit</button>
        <h2 class="text-base font-bold text-slate-900 mb-4">Keahlian</h2>
        <div id="ui-skill-list" class="flex flex-wrap gap-2">
          <% if (parsedSkills.length > 0) { %>
            <% parsedSkills.forEach(function(s) { %>
            <span class="px-4 py-1.5 bg-white border border-slate-200 text-brand-600 text-xs font-medium rounded-full shadow-sm"><%= s.name %></span>
            <% }); %>
          <% } else { %>
          <p class="text-slate-400 text-xs italic">Belum ada keahlian. Klik Edit untuk menambah.</p>
          <% } %>
        </div>
      </div>

      <!-- Pengalaman Kerja -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6 relative">
        <button onclick="document.getElementById('modal-add-exp').classList.add('active')" class="absolute top-5 right-5 inline-flex items-center gap-1 text-xs text-brand-600 hover:underline font-semibold">
          <span class="iconify" data-icon="lucide:plus"></span> Tambah
        </button>
        <h2 class="text-base font-bold text-slate-900 mb-5">Pengalaman Kerja</h2>
        <div id="ui-experiences-list" class="space-y-5">
          <% if (parsedExperiences.length > 0) { %>
            <% parsedExperiences.forEach(function(exp, i) {
              var expInitials = (exp.company || 'XX').substring(0,2).toUpperCase();
              var expBorderClass = (i < parsedExperiences.length-1) ? 'border-b border-slate-100 pb-5' : '';
              var expStartStr = exp.start_date ? new Date(exp.start_date).toLocaleDateString('id-ID',{month:'short',year:'numeric'}) : '-';
              var expEndStr = exp.is_current ? 'Sekarang' : (exp.end_date ? new Date(exp.end_date).toLocaleDateString('id-ID',{month:'short',year:'numeric'}) : '-');
            %>
            <div class="flex gap-3 group" data-exp-id="<%- exp.id %>">
              <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center shrink-0 text-xs font-bold text-brand-700">
                <%- expInitials %>
              </div>
              <div class="flex-1 <%- expBorderClass %>">
                <div class="flex justify-between items-start gap-2">
                  <div>
                    <h3 class="font-bold text-slate-900 text-sm"><%- exp.position %></h3>
                    <p class="text-brand-600 text-xs font-medium mt-0.5"><%- exp.company %></p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class="text-xs text-slate-400"><%- expStartStr %> — <%- expEndStr %></span>
                    <button data-id="<%- exp.id %>" onclick="deleteExperience(this.dataset.id, this)" class="opacity-0 group-hover:opacity-100 text-slate-300 hover:text-red-500 transition-all">
                      <span class="iconify" data-icon="lucide:trash-2"></span>
                    </button>
                  </div>
                </div>
                <% if (exp.description) { %><p class="text-xs text-slate-500 mt-1.5 leading-relaxed"><%- exp.description %></p><% } %>
              </div>
            </div>
            <% }); %>
          <% } else { %>
          <p class="text-slate-400 text-xs italic">Belum ada pengalaman kerja. Klik Tambah di kanan atas.</p>
          <% } %>
        </div>
      </div>

      <!-- Pendidikan -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6 relative">
        <button onclick="document.getElementById('modal-add-edu').classList.add('active')" class="absolute top-5 right-5 inline-flex items-center gap-1 text-xs text-brand-600 hover:underline font-semibold">
          <span class="iconify" data-icon="lucide:plus"></span> Tambah
        </button>
        <h2 class="text-base font-bold text-slate-900 mb-5">Pendidikan</h2>
        <div id="ui-educations-list" class="space-y-3">
          <% if (parsedEducations.length > 0) { %>
            <% parsedEducations.forEach(function(edu) {
              var eduEndYear = edu.end_year || 'Sekarang';
            %>
            <div class="flex gap-4 bg-slate-50 rounded-xl p-4 group" data-edu-id="<%- edu.id %>">
              <div class="w-10 h-10 rounded-full bg-brand-100/60 flex items-center justify-center shrink-0">
                <span class="iconify text-brand-600 text-lg" data-icon="lucide:graduation-cap"></span>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-slate-900 text-sm"><%- edu.degree %> <%- edu.field_of_study %></h3>
                <p class="text-brand-600 text-xs font-medium mt-0.5"><%- edu.school %></p>
                <p class="text-slate-400 text-xs mt-1">
                  <%- edu.start_year %> — <%- eduEndYear %>
                  <% if (edu.gpa) { %> &middot; IPK <%- edu.gpa %><% } %>
                </p>
              </div>
              <button data-id="<%- edu.id %>" onclick="deleteEducation(this.dataset.id, this)" class="opacity-0 group-hover:opacity-100 text-slate-300 hover:text-red-500 transition-all self-start mt-1">
                <span class="iconify" data-icon="lucide:trash-2"></span>
              </button>
            </div>
            <% }); %>
          <% } else { %>
          <p class="text-slate-400 text-xs italic">Belum ada pendidikan. Klik Tambah di kanan atas.</p>
          <% } %>
        </div>
      </div>

      <!-- Portofolio & Proyek Kerja -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6 relative">
        <button onclick="document.getElementById('modal-add-portfolio').classList.add('active')" class="absolute top-5 right-5 inline-flex items-center gap-1 text-xs text-brand-600 hover:underline font-semibold">
          <span class="iconify" data-icon="lucide:plus"></span> Tambah
        </button>
        <h2 class="text-base font-bold text-slate-900 mb-5">Portofolio & Proyek Kerja</h2>
        <div id="ui-portfolios-list" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% let parsedPortfolios = portfolios || []; %>
          <% if (parsedPortfolios.length > 0) { %>
            <% parsedPortfolios.forEach(function(pf) { %>
            <div class="portfolio-card group" data-portfolio-id="<%- pf.id %>">
              <% if (pf.image_url) { %>
                <img src="/images/portfolios/<%- pf.image_url %>" alt="<%- pf.title %>" class="card-img">
              <% } else { %>
                <div class="card-img-placeholder">
                  <span class="iconify text-4xl text-brand-300" data-icon="lucide:layout-dashboard"></span>
                </div>
              <% } %>
              <div class="p-4">
                <h3 class="font-bold text-slate-900 text-sm leading-snug"><%- pf.title %></h3>
                <% if (pf.description) { %><p class="text-xs text-slate-500 mt-1 line-clamp-2"><%- pf.description %></p><% } %>
                <div class="mt-3 flex items-center gap-3">
                  <% if (pf.url) { %>
                  <a href="<%- pf.url %>" target="_blank" class="inline-flex items-center gap-1 text-xs text-brand-600 font-medium hover:underline">
                    <span class="iconify" data-icon="lucide:external-link"></span> Demo
                  </a>
                  <% } %>
                  <% if (pf.github_url) { %>
                  <a href="<%- pf.github_url %>" target="_blank" class="inline-flex items-center gap-1 text-xs text-slate-500 font-medium hover:underline">
                    <span class="iconify" data-icon="lucide:github"></span> GitHub
                  </a>
                  <% } %>
                </div>
              </div>
              <div class="del-overlay">
                <button data-id="<%- pf.id %>" onclick="deletePortfolio(this.dataset.id, this)" class="w-7 h-7 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center shadow-md transition-colors">
                  <span class="iconify text-sm" data-icon="lucide:trash-2"></span>
                </button>
              </div>
            </div>
            <% }); %>
          <% } else { %>
          <div class="col-span-2">
            <p class="text-slate-400 text-xs italic">Belum ada portofolio. Klik Tambah untuk mengunggah proyek Anda.</p>
          </div>
          <% } %>
        </div>
      </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="space-y-5">

      <!-- Statistik -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <h2 class="text-sm font-bold text-slate-900 mb-3">Statistik</h2>
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-brand-50 rounded-xl p-3.5 text-center">
            <p class="text-2xl font-bold text-brand-600"><%= typeof stats !== 'undefined' ? stats.total : 0 %></p>
            <p class="text-[10px] text-slate-500 mt-0.5 font-semibold uppercase tracking-wider">Lamaran</p>
          </div>
          <div class="bg-green-50 rounded-xl p-3.5 text-center">
            <p class="text-2xl font-bold text-green-600"><%= typeof stats !== 'undefined' ? stats.accepted : 0 %></p>
            <p class="text-[10px] text-slate-500 mt-0.5 font-semibold uppercase tracking-wider">Diterima</p>
          </div>
          <div class="bg-amber-50 rounded-xl p-3.5 text-center">
            <p class="text-2xl font-bold text-amber-500"><%= typeof stats !== 'undefined' ? stats.interview : 0 %></p>
            <p class="text-[10px] text-slate-500 mt-0.5 font-semibold uppercase tracking-wider">Wawancara</p>
          </div>
          <div class="bg-slate-50 border border-slate-100 rounded-xl p-3.5 text-center">
            <p class="text-2xl font-bold text-slate-700"><%= typeof stats !== 'undefined' ? stats.pending : 0 %></p>
            <p class="text-[10px] text-slate-500 mt-0.5 font-semibold uppercase tracking-wider">Pending</p>
          </div>
        </div>
      </div>

      <!-- Ekspektasi Gaji -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <h2 class="text-sm font-bold text-slate-900 mb-3">Ekspektasi Gaji</h2>
        <div class="bg-brand-50 border border-brand-100 rounded-xl p-4 text-center">
          <p class="text-xl font-bold text-brand-700" id="ui-salary">
            <% if (salaryMin && salaryMax) { %>Rp <%= formatSalary(salaryMin) %> — <%= formatSalary(salaryMax) %><% } else { %>Belum diatur<% } %>
          </p>
          <p class="text-xs text-brand-500 mt-1">per bulan</p>
        </div>
      </div>

      <!-- Sosial Media -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5">
        <h2 class="text-sm font-bold text-slate-900 mb-3">Sosial Media</h2>
        <div class="space-y-1">
