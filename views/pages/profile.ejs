        </div>
      </div>
      <% if (user.role !== 'hr') { %>
      <!-- Terbuka untuk kerja -->
      <div class="flex items-center justify-between p-3.5 bg-slate-50 rounded-xl border border-slate-100">
        <div>
          <p class="text-sm font-bold text-slate-900">Terbuka untuk kerja</p>
