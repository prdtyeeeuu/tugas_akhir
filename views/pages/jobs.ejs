<!-- Find Jobs Page -->
<% const pageIsLoggedIn = (typeof isLoggedIn !== 'undefined' && isLoggedIn) || (typeof user !== 'undefined' && user); %>
<div class="find-jobs-wrapper">
  <div class="find-jobs-container">
    
    <!-- Header -->
    <div class="find-jobs-header">
      <h1>Temukan Pekerjaan Impianmu</h1>
      <p>Jelajahi ribuan lowongan dari perusahaan terbaik</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div data-alert class="mx-auto mb-6 max-w-3xl rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
        <%= error %>
      </div>
    <% } %>

    <% if (typeof alreadyApplied !== 'undefined' && alreadyApplied) { %>
      <div data-alert class="mx-auto mb-6 max-w-3xl rounded-lg border border-yellow-200 bg-yellow-50 px-4 py-3 text-sm font-medium text-yellow-800">
        Anda sudah melamar untuk pekerjaan ini.
      </div>
    <% } %>

    <!-- Search Bar -->
    <div class="search-bar-container">
      <form action="/jobs" method="GET" class="search-bar">
        <div class="search-icon">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
          </svg>
        </div>
        <input
          type="text"
          name="search"
          value="<%= typeof searchQuery !== 'undefined' && searchQuery ? searchQuery : '' %>"
          placeholder="Cari posisi, perusahaan, atau kata kunci..."
        >
        <input type="hidden" id="selectedCategoriesInput" name="categories" value="<%= typeof selectedCategoryIds !== 'undefined' && selectedCategoryIds.length ? selectedCategoryIds.join(',') : '' %>">
        <button type="submit">Cari</button>
      </form>
    </div>

    <!-- Job Category Sorting Grid (only shown when logged in) -->
    <% if (pageIsLoggedIn) { %>
    <div class="job-sorting-container">
      <h2 class="sorting-title">Jelajahi Kategori Pekerjaan</h2>
      <div id="categoryGrid" class="category-expandable-grid"></div>
      <div id="selectedCategorySummary" class="category-summary"></div>
    </div>
    <% } %>

    <!-- Jobs Grid -->
    <% if (pageIsLoggedIn && typeof jobs !== 'undefined' && jobs && jobs.length > 0) { %>
      <div class="jobs-grid">
        <% jobs.forEach(function(job) { %>
        <div class="job-card" title="Detail Pekerjaan">

          <!-- Card Header -->
          <div class="job-card-header">
            <% if (job.company_logo) { %>
              <img src="/images/companies/<%= job.company_logo %>" alt="Logo <%= job.company %>" class="company-logo">
            <% } else { %>
              <div class="company-logo flex items-center justify-center text-blue-600 font-bold text-xl bg-blue-50 border border-blue-100" style="display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 600; color: white; border: none;">
                <%= job.company ? job.company.charAt(0).toUpperCase() : '?' %>
              </div>
            <% } %>
            <span class="time-posted"><%= formatTimeAgo(job.created_at) %></span>
          </div>

          <!-- Job Info -->
          <div class="job-info">
            <h3 class="job-title"><a href="/jobs/<%= job.id %>" style="text-decoration:none; color:inherit; display:block; cursor:pointer;" class="hover-text-blue"><%= job.title %></a></h3>
            <style>.hover-text-blue:hover { color: #2563eb !important; transition: color 0.2s; }</style>

            <div class="company-info">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M6.5 1.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V2h2a.5.5 0 0 1 .5.5v2h1a.5.5 0 0 1 .5.5v8a.5.5 0 0 1-.5.5H3a.5.5 0 0 1-.5-.5V5.5a.5.5 0 0 1 .5-.5h1V2h2v-.5z"/>
              </svg>
              <span><%= job.company %></span>
            </div>

            <div class="location-info">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
              </svg>
              <span><%= job.location %></span>
            </div>

            <% if (job.category) { %>
            <span class="category-tag"><%= job.category %></span>
            <% } %>

            <!-- Salary Range -->
            <% if (job.salary_min || job.salary_max) { %>
            <div class="salary-info">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M15 1H1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM2 15V2h12v13H2z"/>
                <path d="M4 4a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm4 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm4 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
              </svg>
              <% if (job.salary_min && job.salary_max) { %>
                <span>Rp <%= formatSalary(job.salary_min) %> - <%= formatSalary(job.salary_max) %></span>
              <% } else if (job.salary_min) { %>
                <span>Mulai dari Rp <%= formatSalary(job.salary_min) %></span>
              <% } else if (job.salary_max) { %>
                <span>Hingga Rp <%= formatSalary(job.salary_max) %></span>
              <% } %>
            </div>
            <% } %>
            
            <% if (job.deadline) { 
                 const now = new Date();
                 const isClosed = new Date(job.deadline) < now;
            %>
            <div class="deadline-info" <%- 'style="display:flex; align-items:center; gap:0.5rem; font-size:0.75rem; color:' + (isClosed ? '#ef4444' : '#d97706') + '; margin-top:0.5rem; font-weight: 500;"' %>>
              <svg width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
              </svg>
              <span><%= isClosed ? 'Ditutup' : 'Ditutup pada' %> <%= new Date(job.deadline).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
            </div>
            <% } %>
          </div>

          <!-- Card Footer -->
          <div class="job-card-footer">
            <a href="/user/<%= job.hr_id %>" class="recruiter-info group" style="text-decoration:none; display:flex; gap:12px; align-items:center; cursor:pointer;" title="Lihat Profil">
              <% if (job.hr_image) { %>
                <img src="/images/profiles/<%= job.hr_image %>" class="recruiter-avatar" style="width:36px; height:36px; border-radius:50%; object-fit:cover; border:1px solid #e5e7eb;" alt="HR">
              <% } else { %>
                <div class="recruiter-avatar flex items-center justify-center bg-gray-100 text-gray-500 font-bold" style="width:36px; height:36px; border-radius:50%; font-size:14px; border:1px solid #e5e7eb;">
                  <%= (job.hr_name || 'HR').charAt(0).toUpperCase() %>
                </div>
              <% } %>
              <div class="recruiter-details" style="display:flex; flex-direction:column;">
                <span class="recruiter-name group-hover:text-blue-600 transition-colors duration-200" style="font-size:14px; font-weight:600;"><%= job.hr_name || 'HR Team' %></span>
                <span class="recruiter-role" style="font-size:12px; color:#6b7280;">Recruiter</span>
              </div>
            </a>
            <% if (typeof user !== 'undefined' && user) { %>
              <% 
                 const now = new Date();
                 const deadlinePassed = job.deadline && new Date(job.deadline) < now;
              %>
              <% if (typeof appliedJobIds !== 'undefined' && appliedJobIds.includes(job.id)) { %>
                <button type="button" class="btn-apply" style="background-color: #9ca3af; color: white; cursor: not-allowed; border:none;" disabled title="Anda sudah terdaftar di pekerjaan ini">Dilamar</button>
              <% } else if (deadlinePassed) { %>
                <button type="button" class="btn-apply" style="background-color: #ef4444; color: white; cursor: not-allowed; border:none;" disabled title="Lowongan sudah ditutup">Ditutup</button>
              <% } else { %>
                <button type="button" class="btn-apply" onclick="window.location.href='/jobs/<%= job.id %>'">Lamar</button>
              <% } %>
            <% } else { %>
              <% 
                 const now = new Date();
                 const deadlinePassed = job.deadline && new Date(job.deadline) < now;
              %>
              <% if (deadlinePassed) { %>
                <button type="button" class="btn-apply" style="background-color: #ef4444; color: white; cursor: not-allowed; border:none;" disabled title="Lowongan sudah ditutup">Ditutup</button>
              <% } else { %>
                <a href="/login?returnUrl=/jobs/<%= job.id %>" class="btn-apply">Lamar</a>
              <% } %>
            <% } %>
          </div>

        </div>
        <% }); %>
      </div>
    <% } else if (!pageIsLoggedIn) { %>
      <!-- Login Required CTA -->
      <div class="login-cta-card">
        <svg width="80" height="80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H6m8 0a2 2 0 012 2v6M6 6a2 2 0 012-2m0 0V2m0 2H6a2 2 0 00-2 2v6a2 2 0 002 2h12a2 2 0 002-2V8a2 2 0 00-2-2z"/>
        </svg>
        <h3>Masuk untuk Melihat Lowongan</h3>
        <p>Login untuk menjelajahi semua lowongan pekerjaan yang tersedia. Temukan pekerjaan yang cocok dengan keahlian dan pengalamanmu.</p>
        <div class="login-cta-buttons">
          <a href="/login" class="cta-btn-login primary">Masuk Sekarang</a>
          <a href="/register" class="cta-btn-login outline">Daftar Gratis</a>
        </div>
      </div>
    <% } else { %>
      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-icon">💼</div>
        <h3>Tidak ada pekerjaan ditemukan</h3>
        <p>Coba ubah filter atau kata kunci pencarian Anda</p>
      </div>
    <% } %>

  </div>
</div>

<!-- Category Modal -->
<div id="categoryModal" class="category-modal hidden" aria-hidden="true">
  <div class="category-modal-backdrop" data-close-category-modal></div>
  <div class="category-modal-card" role="dialog" aria-modal="true" aria-labelledby="categoryModalTitle">
    <div class="category-modal-header">
      <div>
        <h3 id="categoryModalTitle">Pilih Kategori</h3>
        <p>Pilih satu atau beberapa kategori pekerjaan.</p>
      </div>
      <button type="button" class="category-modal-close" data-close-category-modal aria-label="Tutup modal kategori">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div id="categoryModalGrid" class="category-modal-grid"></div>

    <div class="category-modal-actions">
      <button type="button" id="clearCategoryFilter" class="category-action secondary">Reset</button>
      <button type="button" id="applyCategoryFilter" class="category-action primary">Terapkan Filter</button>
    </div>
  </div>
</div>

<script>
  const selectedCategories = <%- JSON.stringify(typeof selectedCategoryIds !== 'undefined' ? selectedCategoryIds : []) %>;
  let allCategories = [];
  let popularCategories = [];

  document.addEventListener('DOMContentLoaded', async function() {
    await loadCategories();
    bindCategoryModal();
  });

  async function loadCategories() {
    try {
      const [popularResponse, allResponse] = await Promise.all([
        fetch('/api/categories/popular'),
        fetch('/api/categories/all')
      ]);
      const popularResult = await popularResponse.json();
      const allResult = await allResponse.json();

      if (!popularResponse.ok || !popularResult.success) {
        throw new Error(popularResult.message || 'Gagal memuat kategori populer');
      }

      if (!allResponse.ok || !allResult.success) {
        throw new Error(allResult.message || 'Gagal memuat semua kategori');
      }

      popularCategories = popularResult.data || [];
      allCategories = allResult.data || [];
      renderPrimaryCategoryGrid();
      renderCategoryModalGrid();
      updateSelectedCategorySummary();
    } catch (error) {
      console.error('Load categories error:', error);
    }
  }

  function renderPrimaryCategoryGrid() {
    const grid = document.getElementById('categoryGrid');
    if (!grid) return;

    const cards = popularCategories.slice(0, 6).map(category => {
      const activeClass = selectedCategories.includes(category.id) ? 'active' : '';
      return `
        <button type="button" class="category-card-filter ${activeClass}" data-category-id="${category.id}">
          <span class="category-card-icon">
            <i data-lucide="${getLucideIconName(category.icon_name)}"></i>
          </span>
          <span class="category-card-name">${escapeHtml(category.name)}</span>
        </button>
      `;
    });

    cards.push(`
      <button type="button" class="category-card-filter more" id="openCategoryModal">
        <span class="category-card-icon">
          <i data-lucide="more-horizontal"></i>
        </span>
        <span class="category-card-name">Lainnya</span>
      </button>
    `);

    grid.innerHTML = cards.join('');

    grid.querySelectorAll('[data-category-id]').forEach(button => {
      button.addEventListener('click', function() {
        toggleCategory(Number(this.dataset.categoryId));
        applyCategoryFilter();
      });
    });

    const openButton = document.getElementById('openCategoryModal');
    if (openButton) {
      openButton.addEventListener('click', openCategoryModal);
    }

    renderLucideIcons();
  }

  function renderCategoryModalGrid() {
    const modalGrid = document.getElementById('categoryModalGrid');
    if (!modalGrid) return;

    modalGrid.innerHTML = allCategories.map(category => {
      const checked = selectedCategories.includes(category.id) ? 'checked' : '';
      return `
        <label class="category-checkbox-card">
          <input type="checkbox" value="${category.id}" ${checked}>
          <span class="category-checkbox-icon">
            <i data-lucide="${getLucideIconName(category.icon_name)}"></i>
          </span>
          <span class="category-checkbox-name">${escapeHtml(category.name)}</span>
        </label>
      `;
    }).join('');

    modalGrid.querySelectorAll('input[type="checkbox"]').forEach(input => {
      input.addEventListener('change', function() {
        const categoryId = Number(this.value);
        if (this.checked && !selectedCategories.includes(categoryId)) {
          selectedCategories.push(categoryId);
        }
        if (!this.checked) {
          const index = selectedCategories.indexOf(categoryId);
          if (index > -1) selectedCategories.splice(index, 1);
        }
        updateSelectedCategorySummary();
      });
    });

    renderLucideIcons();
  }

  function bindCategoryModal() {
    document.querySelectorAll('[data-close-category-modal]').forEach(element => {
      element.addEventListener('click', closeCategoryModal);
    });

    const applyButton = document.getElementById('applyCategoryFilter');
    if (applyButton) {
      applyButton.addEventListener('click', applyCategoryFilter);
    }

    const clearButton = document.getElementById('clearCategoryFilter');
    if (clearButton) {
      clearButton.addEventListener('click', function() {
        selectedCategories.splice(0, selectedCategories.length);
        renderPrimaryCategoryGrid();
        renderCategoryModalGrid();
        updateSelectedCategorySummary();
      });
    }
  }

  function toggleCategory(categoryId) {
    const index = selectedCategories.indexOf(categoryId);
    if (index > -1) {
      selectedCategories.splice(index, 1);
    } else {
      selectedCategories.push(categoryId);
    }
    renderPrimaryCategoryGrid();
    renderCategoryModalGrid();
    updateSelectedCategorySummary();
  }

  function applyCategoryFilter() {
    const params = new URLSearchParams(window.location.search);
    const searchInput = document.querySelector('input[name="search"]');
    const searchValue = searchInput ? searchInput.value.trim() : '';

    if (searchValue) {
      params.set('search', searchValue);
    } else {
      params.delete('search');
    }

    if (selectedCategories.length > 0) {
      params.set('categories', selectedCategories.join(','));
    } else {
      params.delete('categories');
    }

    params.delete('category');
    params.delete('page');

    window.location.href = `/jobs${params.toString() ? '?' + params.toString() : ''}`;
  }

  function openCategoryModal() {
    const modal = document.getElementById('categoryModal');
    if (!modal) return;
    modal.classList.remove('hidden');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeCategoryModal() {
    const modal = document.getElementById('categoryModal');
    if (!modal) return;
    modal.classList.add('hidden');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function updateSelectedCategorySummary() {
    const summary = document.getElementById('selectedCategorySummary');
    const hiddenInput = document.getElementById('selectedCategoriesInput');
    if (hiddenInput) hiddenInput.value = selectedCategories.join(',');
    if (!summary) return;

    if (selectedCategories.length === 0) {
      summary.textContent = 'Semua kategori ditampilkan.';
      return;
    }

    const names = allCategories
      .filter(category => selectedCategories.includes(category.id))
      .map(category => category.name);

    summary.textContent = `${selectedCategories.length} kategori dipilih: ${names.join(', ')}`;
  }

  function getLucideIconName(iconName) {
    const normalizedName = String(iconName || '').trim();
    if (!normalizedName) {
      return 'briefcase';
    }

    if (!window.lucide || !window.lucide.icons) {
      return normalizedName;
    }

    return window.lucide.icons[toPascalCase(normalizedName)] ? normalizedName : 'briefcase';
  }

  function toPascalCase(value) {
    return String(value)
      .split('-')
      .filter(Boolean)
      .map(part => part.charAt(0).toUpperCase() + part.slice(1))
      .join('');
  }

  function renderLucideIcons() {
    if (window.lucide && typeof window.lucide.createIcons === 'function') {
      window.lucide.createIcons({
        attrs: {
          width: 24,
          height: 24,
          'stroke-width': 2
        }
      });
    }
  }

  function escapeHtml(value) {
    return String(value || '').replace(/[&<>"']/g, function(char) {
      return {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      }[char];
    });
  }

  // Helper function to format salary
  function formatSalary(amount) {
    if (!amount) return '';
    if (amount >= 1000000) {
      return (amount / 1000000).toFixed(amount % 1000000 === 0 ? 0 : 1) + ' jt';
    } else if (amount >= 1000) {
      return (amount / 1000).toFixed(0) + ' rb';
    }
    return amount.toString();
  }

  // Helper function to format time ago
  function formatTimeAgo(dateString) {
    const now = new Date();
    const date = new Date(dateString);
    const seconds = Math.floor((now - date) / 1000);

    const intervals = [
      { label: 'tahun', seconds: 31536000 },
      { label: 'bulan', seconds: 2592000 },
      { label: 'minggu', seconds: 604800 },
      { label: 'hari', seconds: 86400 },
      { label: 'jam', seconds: 3600 },
      { label: 'menit', seconds: 60 }
    ];

    for (const interval of intervals) {
      const count = Math.floor(seconds / interval.seconds);
      if (count >= 1) {
        if (interval.label === 'jam') {
          return count + ' jam lalu';
        } else if (interval.label === 'menit') {
          return count < 60 ? 'Baru Saja' : count + ' menit lalu';
        } else if (interval.label === 'hari') {
          if (count === 1) return '1 hari lalu';
          if (count < 7) return count + ' hari lalu';
        }
        break;
      }
    }

    if (seconds < 60) return 'Baru Saja';
    return Math.floor(seconds / 3600) + ' jam lalu';
  }
</script>
