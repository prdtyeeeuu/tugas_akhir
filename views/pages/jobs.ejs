<!-- Find Jobs Page -->
<div class="find-jobs-wrapper">
  <div class="find-jobs-container">
    
    <!-- Header -->
    <div class="find-jobs-header">
      <h1>Temukan Pekerjaan Impianmu</h1>
      <p>Jelajahi ribuan lowongan dari perusahaan terbaik</p>
    </div>

    <!-- Search Bar -->
    <div class="search-bar-container">
      <form action="/jobs" method="GET" class="search-bar">
        <div class="search-icon">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
          </svg>
        </div>
        <input
          type="text"
          name="search"
          value="<%= typeof searchQuery !== 'undefined' && searchQuery ? searchQuery : '' %>"
          placeholder="Cari posisi, perusahaan, atau kata kunci..."
        >
        <input type="hidden" name="category" value="<%= typeof selectedCategory !== 'undefined' && selectedCategory ? selectedCategory : '' %>">
        <button type="submit">Cari</button>
      </form>
    </div>

    <!-- Category Filter Buttons -->
    <div class="category-filters">
      <a href="/jobs" class="category-btn <%= typeof selectedCategory === 'undefined' || !selectedCategory ? 'active' : '' %>">Semua</a>
      <% if (typeof categories !== 'undefined' && categories) { %>
        <% categories.forEach(function(cat) { %>
          <a
            href="/jobs?category=<%= cat.category %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>"
            class="category-btn <%= typeof selectedCategory !== 'undefined' && selectedCategory === cat.category ? 'active' : '' %>"
          >
            <%= cat.category %>
          </a>
        <% }); %>
      <% } %>
    </div>

    <!-- Jobs Grid -->
    <% if (typeof jobs !== 'undefined' && jobs && jobs.length > 0) { %>
      <div class="jobs-grid">
        <% jobs.forEach(function(job) { %>
        <div class="job-card">
          
          <!-- Card Header -->
          <div class="job-card-header">
            <% if (job.company_logo) { %>
              <img src="/images/companies/<%= job.company_logo %>" alt="Logo <%= job.company %>" class="company-logo">
            <% } else { %>
              <div class="company-logo flex items-center justify-center text-blue-600 font-bold text-xl bg-blue-50 border border-blue-100" style="display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 600; color: white; border: none;">
                <%= job.company ? job.company.charAt(0).toUpperCase() : '?' %>
              </div>
            <% } %>
            <span class="time-posted"><%= formatTimeAgo(job.created_at) %></span>
          </div>

          <!-- Job Info -->
          <div class="job-info">
            <h3 class="job-title"><%= job.title %></h3>
            
            <div class="company-info">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M6.5 1.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V2h2a.5.5 0 0 1 .5.5v2h1a.5.5 0 0 1 .5.5v8a.5.5 0 0 1-.5.5H3a.5.5 0 0 1-.5-.5V5.5a.5.5 0 0 1 .5-.5h1V2h2v-.5z"/>
              </svg>
              <span><%= job.company %></span>
            </div>

            <div class="location-info">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/>
              </svg>
              <span><%= job.location %></span>
            </div>

            <% if (job.category) { %>
            <span class="category-tag"><%= job.category %></span>
            <% } %>

            <!-- Salary Range -->
            <% if (job.salary_min || job.salary_max) { %>
            <div class="salary-info">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M15 1H1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM2 15V2h12v13H2z"/>
                <path d="M4 4a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm4 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm4 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
              </svg>
              <% if (job.salary_min && job.salary_max) { %>
                <span>Rp <%= formatSalary(job.salary_min) %> - <%= formatSalary(job.salary_max) %></span>
              <% } else if (job.salary_min) { %>
                <span>Mulai dari Rp <%= formatSalary(job.salary_min) %></span>
              <% } else if (job.salary_max) { %>
                <span>Hingga Rp <%= formatSalary(job.salary_max) %></span>
              <% } %>
            </div>
            <% } %>
          </div>

          <!-- Card Footer -->
          <div class="job-card-footer">
            <div class="recruiter-info">
              <div class="recruiter-avatar"></div>
              <div class="recruiter-details">
                <span class="recruiter-name"><%= job.hr_name || 'HR Team' %></span>
                <span class="recruiter-role">Recruiter</span>
              </div>
            </div>

            <% if (typeof user !== 'undefined' && user) { %>
              <form action="/jobs/apply/<%= job.id %>" method="POST" class="inline">
                <button type="submit" class="btn-apply">Lamar</button>
              </form>
            <% } else { %>
              <a href="/login?returnUrl=/jobs/<%= job.id %>" class="btn-apply">Lamar</a>
            <% } %>
          </div>

        </div>
        <% }); %>
      </div>
    <% } else { %>
      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-icon">💼</div>
        <h3>Tidak ada pekerjaan ditemukan</h3>
        <p>Coba ubah filter atau kata kunci pencarian Anda</p>
      </div>
    <% } %>

  </div>
</div>

<script>
  // Helper function to format salary
  function formatSalary(amount) {
    if (!amount) return '';
    if (amount >= 1000000) {
      return (amount / 1000000).toFixed(amount % 1000000 === 0 ? 0 : 1) + ' jt';
    } else if (amount >= 1000) {
      return (amount / 1000).toFixed(0) + ' rb';
    }
    return amount.toString();
  }

  // Helper function to format time ago
  function formatTimeAgo(dateString) {
    const now = new Date();
    const date = new Date(dateString);
    const seconds = Math.floor((now - date) / 1000);

    const intervals = [
      { label: 'tahun', seconds: 31536000 },
      { label: 'bulan', seconds: 2592000 },
      { label: 'minggu', seconds: 604800 },
      { label: 'hari', seconds: 86400 },
      { label: 'jam', seconds: 3600 },
      { label: 'menit', seconds: 60 }
    ];

    for (const interval of intervals) {
      const count = Math.floor(seconds / interval.seconds);
      if (count >= 1) {
        if (interval.label === 'jam') {
          return count + ' jam lalu';
        } else if (interval.label === 'menit') {
          return count < 60 ? 'Baru Saja' : count + ' menit lalu';
        } else if (interval.label === 'hari') {
          if (count === 1) return '1 hari lalu';
          if (count < 7) return count + ' hari lalu';
        }
        break;
      }
    }

    if (seconds < 60) return 'Baru Saja';
    return Math.floor(seconds / 3600) + ' jam lalu';
  }
</script>
