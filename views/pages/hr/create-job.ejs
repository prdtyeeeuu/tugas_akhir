<!-- HR Create Job Page -->
<style>
  .hr-page {
    background-color: #f5f7fa;
    min-height: calc(100vh - 64px);
  }
  
  .hr-nav {
    background: white;
    border-bottom: 1px solid #e5e7eb;
  }
  
  .hr-nav-link {
    padding: 1rem 1.5rem;
    color: #6b7280;
    font-weight: 500;
    transition: all 0.2s;
    border-bottom: 2px solid transparent;
  }
  
  .hr-nav-link:hover {
    color: #3b82f6;
  }
  
  .hr-nav-link.active {
    color: #3b82f6;
    border-bottom-color: #3b82f6;
  }
  
  .form-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .form-card {
    background: white;
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.01);
    border: 1px solid #f3f4f6;
  }
  
  .form-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px dashed #f3f4f6;
    text-align: center;
  }
  
  .form-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #111827;
    background: linear-gradient(135deg, #111827 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .form-header p {
    color: #6b7280;
    margin-top: 0.5rem;
    font-size: 0.95rem;
  }
  
  .form-group {
    margin-bottom: 1.5rem;
  }
  
  .form-label {
    display: block;
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
  }
  
  .form-label .required {
    color: #ef4444;
  }
  
  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.875rem 1.25rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    font-size: 0.95rem;
    transition: all 0.25s ease;
    background-color: #f9fafb;
  }
  
  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #3b82f6;
    background-color: white;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  }
  
  .form-textarea {
    min-height: 150px;
    resize: vertical;
  }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  
  .form-hint {
    font-size: 0.75rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }
  
  .error-message {
    background: #fee2e2;
    border: 1px solid #fecaca;
    color: #dc2626;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .btn-submit {
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    padding: 1rem 2rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1.05rem;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.2), 0 2px 4px -1px rgba(59, 130, 246, 0.1);
  }
  
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3), 0 4px 6px -2px rgba(59, 130, 246, 0.1);
  }
  
  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6b7280;
    font-weight: 500;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }
  
  .btn-back:hover {
    color: #3b82f6;
  }
  
  .user-menu {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #3b82f6;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.875rem;
  }
  
  .user-name {
    font-weight: 500;
    color: #111827;
    font-size: 0.875rem;
  }
  
  .salary-input-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .salary-prefix {
    padding: 0.875rem 1.25rem;
    background: #f3f4f6;
    border: 1.5px solid #e5e7eb;
    border-right: none;
    border-radius: 10px 0 0 10px;
    font-size: 0.95rem;
    color: #6b7280;
    font-weight: 600;
  }
  
  .salary-input-group .form-input {
    border-radius: 0 10px 10px 0;
  }
  
  /* Category Pills Styling */
  .category-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  
  .category-checkbox {
    display: none;
  }
  
  .category-label {
    padding: 0.6rem 1.25rem;
    background: #f3f4f6;
    border: 1.5px solid #e5e7eb;
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: #4b5563;
    transition: all 0.2s ease;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .category-label::before {
    content: '+';
    font-size: 1rem;
    font-weight: bold;
    color: #9ca3af;
    transition: all 0.2s;
  }
  
  .category-checkbox:checked + .category-label {
    background: #eff6ff;
    color: #1d4ed8;
    border-color: #3b82f6;
    box-shadow: 0 0 0 1px #3b82f6;
  }
  
  .category-checkbox:checked + .category-label::before {
    content: '✓';
    color: #3b82f6;
  }
  
  .category-label:hover {
    background: #e5e7eb;
    transform: translateY(-1px);
  }
  
  .category-checkbox:checked + .category-label:hover {
    background: #dbeafe;
  }
.req-group { margin-bottom: 1.25rem; } .req-group-title { font-size: 0.875rem; font-weight: 600; color: #4b5563; margin-bottom: 0.75rem; } .req-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; } .req-checkbox { display: none; } .req-label { padding: 0.5rem 1rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 9999px; cursor: pointer; font-size: 0.8125rem; font-weight: 500; color: #4b5563; transition: all 0.2s ease; user-select: none; } .req-label:hover { background: #e5e7eb; } .req-checkbox:checked + .req-label { background: #3b82f6; border-color: #3b82f6; color: white; } .req-checkbox:checked + .req-label:hover { background: #2563eb; }
</style>

<div class="hr-page">


  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <a href="/hr/jobs" class="btn-back">
      <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
      </svg>
      Kembali ke Kelola Lowongan
    </a>

    <div class="form-container">
      <div class="form-card">
        <div class="form-header">
          <h1>📝 Pasang Lowongan Baru</h1>
          <p>Isi form di bawah untuk membuat lowongan pekerjaan baru</p>
        </div>

        <% if (error) { %>
          <div class="error-message">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
            </svg>
            <%= error %>
          </div>
        <% } %>

        <form action="/hr/jobs?_csrf=<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" method="POST" enctype="multipart/form-data">
          <!-- Judul Lowongan -->
          <div class="form-group">
            <label class="form-label">
              Judul Lowongan <span class="required">*</span>
            </label>
            <input 
              type="text" 
              name="title" 
              class="form-input" 
              placeholder="Contoh: Frontend Developer, UI/UX Designer"
              value="<%= formData.title || '' %>"
              required
            >
            <p class="form-hint">Gunakan judul yang jelas dan spesifik</p>
          </div>

          <!-- Perusahaan & Lokasi -->
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">
                Perusahaan <span class="required">*</span>
              </label>
              <input 
                type="text" 
                name="company" 
                class="form-input" 
                placeholder="Nama perusahaan"
                value="<%= formData.company || '' %>"
                required
              >
            </div>
            <div class="form-group">
              <label class="form-label">
                Logo Perusahaan (Opsional)
              </label>
              <input 
                type="file" 
                name="company_logo" 
                class="form-input" 
                accept="image/jpeg, image/png, image/webp"
              >
              <p class="form-hint">Format yang diizinkan: JPG, PNG, WEBP (Maks 5MB)</p>
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">
                Lokasi <span class="required">*</span>
              </label>
              <input 
                type="text" 
                name="location" 
                class="form-input" 
                placeholder="Contoh: Jakarta, Bandung, Remote"
                value="<%= formData.location || '' %>"
                required
              >
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">
              Alamat Lengkap Tempat Kerja <span class="required">*</span>
            </label>
            <textarea
              name="work_address"
              class="form-textarea"
              style="min-height: 110px;"
              placeholder="Contoh: Jl. Sudirman No. 10, Lantai 5, Karet Tengsin, Tanah Abang, Jakarta Pusat, DKI Jakarta 10220"
              required
            ><%= formData.work_address || '' %></textarea>
            <p class="form-hint">Alamat ini akan dipakai pada dokumen offering letter bagian Lokasi Kerja.</p>
          </div>

          <!-- Kategori -->
          <div class="form-group">
            <label class="form-label">
              Kategori Pekerjaan <span class="required">*</span>
              <span class="text-xs text-gray-500 font-normal ml-2">(Pilih satu atau lebih kategori yang sesuai)</span>
            </label>
            
            <%
              const categories = [
                'Administrasi & Operasional',
                'Sales & Business Dev',
                'Pemasaran & PR',
                'Keuangan & Akuntansi',
                'Customer Service',
                'Logistik & Supply Chain',
                'Sumber Daya Manusia',
                'Teknologi Informasi',
                'Frontend Developer',
                'Backend Developer',
                'Full Stack Developer',
                'Mobile Developer',
                'UI/UX Designer',
                'Data Scientist',
                'DevOps Engineer',
                'Cyber Security',
                'Quality Assurance',
                'Cloud Architect',
                'Game Developer',
                'AI & Machine Learning',
                'Kesehatan & Medis',
                'Pendidikan & Pelatihan',
                'Desain Grafis & Kreatif',
                'Hukum & Kepatuhan',
                'Konstruksi & Properti',
                'Perhotelan & Pariwisata',
                'Restoran & Food Service',
                'Transportasi',
                'Pertambangan & Energi',
                'E-commerce',
                'Lainnya'
              ];
              
              // Handle formData.category string or array
              const selectedCats = formData.category 
                ? (Array.isArray(formData.category) ? formData.category : formData.category.split(', '))
                : [];
            %>
            
            <div class="category-grid" id="categoryGrid">
              <% categories.forEach((cat, idx) => { %>
                <input 
                  type="checkbox" 
                  id="cat-<%= idx %>" 
                  name="category" 
                  value="<%= cat %>" 
                  class="category-checkbox" 
                  <%= selectedCats.includes(cat) ? 'checked' : '' %>
                >
                <label for="cat-<%= idx %>" class="category-label"><%= cat %></label>
              <% }); %>
            </div>
          </div>

          <!-- Tipe Pekerjaan -->
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Tipe Pekerjaan</label>
              <select name="type" class="form-select">
                <option value="Full-time" <%= (!formData.type || formData.type === 'Full-time') ? 'selected' : '' %>>Full-time</option>
                <option value="Part-time" <%= formData.type === 'Part-time' ? 'selected' : '' %>>Part-time</option>
                <option value="Remote" <%= formData.type === 'Remote' ? 'selected' : '' %>>Remote</option>
                <option value="Contract" <%= formData.type === 'Contract' ? 'selected' : '' %>>Contract</option>
                <option value="Internship" <%= formData.type === 'Internship' ? 'selected' : '' %>>Internship</option>
              </select>
            </div>
            
            <div class="form-group">
              <label class="form-label">Tenggat Waktu / Deadline (Opsional)</label>
              <input 
                type="date" 
                name="deadline" 
                class="form-input"
                value="<%= formData.deadline || '' %>"
              >
              <p class="form-hint">Kosongkan jika lowongan tidak memiliki batas waktu</p>
            </div>
          </div>

          <!-- Range Gaji -->
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Gaji Minimum (Rp)</label>
              <div class="salary-input-group">
                <span class="salary-prefix">Rp</span>
                <input 
                  type="number" 
                  name="salary_min" 
                  class="form-input" 
                  placeholder="5000000"
                  value="<%= formData.salary_min || '' %>"
                >
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Gaji Maksimum (Rp)</label>
              <div class="salary-input-group">
                <span class="salary-prefix">Rp</span>
                <input 
                  type="number" 
                  name="salary_max" 
                  class="form-input" 
                  placeholder="10000000"
                  value="<%= formData.salary_max || '' %>"
                >
              </div>
            </div>
          </div>
          <p class="form-hint mb-6">Opsional - Kosongkan jika tidak ingin menampilkan range gaji</p>

          <!-- Kualifikasi Pekerjaan -->
          <div class="form-group">
            <label class="form-label">
              Kualifikasi Pekerjaan (Opsional)
            </label>
            <p class="form-hint mb-3" style="margin-bottom: 1rem;">Pilih kualifikasi yang relevan dengan posisi ini</p>
            
            <%
              const requirementGroups = {
                "Identitas Dasar": ["Laki-laki", "Perempuan", "Usia Maksimal 25", "Usia Maksimal 30", "Usia Maksimal 35", "Single/Belum Menikah"],
                "Pendidikan": ["Minimal SMK/SMA", "Minimal D3", "Minimal S1"],
                "Pengalaman": ["Fresh Graduate", "> 1 Tahun", "> 3 Tahun", "> 5 Tahun"],
                "Soft Skills": ["Kerja Tim", "Komunikasi Efektif", "Problem Solving", "Disiplin/Deadline"],
                "Lokasi & Fisik": ["Bersedia Penempatan Kantor", "Remote/WFH", "Sehat Jasmani", "Memiliki Kendaraan Pribadi"]
              };
              
              const selectedReqs = formData.requirements 
                ? (Array.isArray(formData.requirements) ? formData.requirements : [formData.requirements])
                : [];
              let reqIdx = 0;
            %>
            
            <div id="requirements-container">
              <% Object.keys(requirementGroups).forEach(groupName => { %>
                <div class="req-group">
                  <div class="req-group-title"><%= groupName %></div>
                  <div class="req-grid">
                    <% requirementGroups[groupName].forEach(req => { %>
                      <input 
                        type="checkbox" 
                        id="req-<%= reqIdx %>" 
                        name="requirements" 
                        value="<%= req %>" 
                        class="req-checkbox"
                        <%= selectedReqs.includes(req) ? 'checked' : '' %>
                      >
                      <label for="req-<%= reqIdx %>" class="req-label"><%= req %></label>
                      <% reqIdx++; %>
                    <% }); %>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Deskripsi Lowongan -->
          <div class="form-group">
            <label class="form-label">
              Deskripsi Lowongan <span class="required">*</span>
            </label>
            <textarea 
              name="description" 
              class="form-textarea" 
              placeholder="Jelaskan detail tentang posisi, tanggung jawab, kualifikasi, dan benefit yang ditawarkan..."
              required
            ><%= formData.description || '' %></textarea>
            <p class="form-hint">Sertakan detail tentang tanggung jawab, kualifikasi, dan benefit</p>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="btn-submit" id="btnSubmitForm">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16" style="display: inline; margin-right: 8px; vertical-align: middle; margin-top: -2px;">
              <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
            </svg>
            Publikasikan Lowongan
          </button>
        </form>
      </div>
    </div>
  </div>

<script>
  // Validasi agar setidaknya 1 kategori dipilih
  document.querySelector('form').addEventListener('submit', function(e) {
    const checkedCategories = document.querySelectorAll('.category-checkbox:checked');
    if (checkedCategories.length === 0) {
      e.preventDefault();
      
      // Tambahkan efek shake dan outline merah ke grid kategori
      const grid = document.getElementById('categoryGrid');
      grid.style.padding = '0.5rem';
      grid.style.border = '1px solid #ef4444';
      grid.style.borderRadius = '12px';
      grid.style.backgroundColor = '#fef2f2';
      
      // Scroll ke bagian kategori
      grid.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Tampilkan notifikasi
      customAlert('Mohon pilih minimal satu kategori pekerjaan!', 'Perhatian');
      
      // Kembalikan style setelah 3 detik
      setTimeout(() => {
        grid.style.padding = '';
        grid.style.border = '';
        grid.style.borderRadius = '';
        grid.style.backgroundColor = '';
      }, 3000);
    }
  });
</script>
