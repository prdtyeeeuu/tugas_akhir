<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="flex-1 min-w-0">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        Manajemen Gambar
      </h2>
      <p class="mt-1 text-sm text-gray-500">Kelola gambar berdasarkan kategori (Banner, Porto, Profil).</p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <a href="/admin/dashboard" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        Kembali ke Dashboard
      </a>
    </div>
  </div>

  <% const categoryNames = { banners: 'Banners', portfolios: 'Portfolios (Porto)', profiles: 'Profiles (Profil)' }; %>
  <% Object.keys(imagesByCategory).forEach(category => { %>
    <div class="mb-12">
      <h3 class="text-xl font-bold text-gray-800 mb-4 pb-2 border-b border-gray-200">
        <%= categoryNames[category] || category %>
        <span class="text-sm font-normal text-gray-500 ml-2">(<%= imagesByCategory[category].length %> gambar)</span>
      </h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% if (imagesByCategory[category] && imagesByCategory[category].length > 0) { %>
          <% imagesByCategory[category].forEach(img => { %>
            <div class="bg-white rounded-lg shadow overflow-hidden border border-gray-200 flex flex-col">
              <div class="h-48 w-full bg-gray-100 flex items-center justify-center p-2">
                <img src="/images/<%= category %>/<%= img.filename %>" alt="<%= img.filename %>" class="max-h-full max-w-full object-contain">
              </div>
              <div class="p-4 flex-grow flex flex-col justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900 truncate" title="<%= img.filename %>"><%= img.filename %></p>
                  <p class="text-xs text-gray-500 mt-1">
                    <span class="font-medium text-gray-700">Ditambahkan oleh:</span> <%= img.uploader_name %>
                  </p>
                  <p class="text-xs text-gray-400 mt-1"><%= img.size %> • <%= new Date(img.created_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                </div>
                <div class="mt-4 flex space-x-2">
                  <button type="button" onclick="openExamineModal('/images/<%= category %>/<%= img.filename %>', '<%= img.filename %>')" class="flex-1 text-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Periksa
                  </button>
                  <form action="/admin/images/<%= category %>/<%= img.filename %>?_method=DELETE" method="POST" class="flex-1" onsubmit="return handleConfirm(this, event, 'Apakah Anda yakin ingin menghapus gambar ini secara permanen?');">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <button type="submit" class="w-full text-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                      Hapus
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full py-8 text-center bg-gray-50 rounded-lg border border-dashed border-gray-300">
            <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Tidak ada gambar</h3>
            <p class="mt-1 text-sm text-gray-500">Folder <%= category %> saat ini kosong.</p>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<!-- Modal untuk Examine Gambar -->
<div id="examineModal" class="fixed inset-0 z-50 hidden bg-black bg-opacity-75 flex items-center justify-center p-4 transition-opacity duration-300">
  <div class="relative max-w-5xl w-full max-h-full flex flex-col bg-white rounded-lg overflow-hidden shadow-2xl">
    <div class="flex items-center justify-between p-4 border-b border-gray-200">
      <h3 id="modalTitle" class="text-lg font-medium text-gray-900 truncate">Nama Gambar</h3>
      <button type="button" onclick="closeExamineModal()" class="text-gray-400 hover:text-gray-500 focus:outline-none">
        <span class="sr-only">Tutup</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="flex-grow overflow-auto p-4 flex items-center justify-center bg-gray-100 min-h-[300px]">
      <img id="modalImage" src="" alt="Gambar Diperiksa" class="max-w-full max-h-[70vh] object-contain">
    </div>
    <div class="p-4 border-t border-gray-200 flex justify-end">
      <button type="button" onclick="closeExamineModal()" class="px-4 py-2 bg-gray-600 text-white rounded-md shadow-sm text-sm font-medium hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
        Kembali
      </button>
    </div>
  </div>
</div>

<script>
  function openExamineModal(imgSrc, title) {
    document.getElementById('modalImage').src = imgSrc;
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('examineModal').classList.remove('hidden');
  }

  function closeExamineModal() {
    document.getElementById('examineModal').classList.add('hidden');
    // Bersihkan source gambar setelah ditutup
    setTimeout(() => { document.getElementById('modalImage').src = ''; }, 300);
  }
</script>
