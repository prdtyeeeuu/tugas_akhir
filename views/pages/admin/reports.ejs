<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="md:flex md:items-center md:justify-between mb-8">
    <div class="flex-1 min-w-0">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        Laporan Pengguna & Lowongan
      </h2>
      <p class="mt-1 text-sm text-gray-500">Tinjau laporan scam, lowongan palsu, atau aktivitas tidak pantas.</p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4 gap-2">
      <% ['pending','reviewed','resolved','dismissed','all'].forEach(function(st) { %>
        <a href="/admin/reports?status=<%= st %>" class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium border <%= selectedStatus === st ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50' %>">
          <%= st === 'all' ? 'Semua' : st %>
        </a>
      <% }); %>
    </div>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-800">
      <%= success %>
    </div>
  <% } %>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800">
      <%= error %>
    </div>
  <% } %>

  <div class="space-y-4">
    <% if (reports && reports.length > 0) { %>
      <% reports.forEach(function(report) {
        const isJob = report.target_type === 'job';
        const targetTitle = isJob
          ? (report.target_job_title || 'Lowongan terhapus')
          : (report.target_user_name || 'User terhapus');
        const targetMeta = isJob
          ? `${report.target_job_company || '-'}${report.target_job_hr_name ? ' oleh ' + report.target_job_hr_name : ''}`
          : (report.target_user_email || '-');
        const statusClass = report.status === 'pending'
          ? 'bg-yellow-100 text-yellow-800'
          : report.status === 'resolved'
            ? 'bg-green-100 text-green-800'
            : report.status === 'dismissed'
              ? 'bg-red-100 text-red-800'
              : 'bg-blue-100 text-blue-800';
      %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="px-2 py-1 rounded-full text-xs font-semibold <%= isJob ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                <%= isJob ? 'Lowongan' : 'User' %>
              </span>
              <span class="px-2 py-1 rounded-full text-xs font-semibold <%= statusClass %>"><%= report.status %></span>
              <span class="text-xs text-gray-400"><%= new Date(report.created_at).toLocaleString('id-ID') %></span>
            </div>
            <h3 class="text-lg font-bold text-gray-900"><%= targetTitle %></h3>
            <p class="text-sm text-gray-500"><%= targetMeta %></p>
            <div class="mt-3 grid md:grid-cols-2 gap-4">
              <div>
                <p class="text-xs font-semibold text-gray-400 uppercase">Pelapor</p>
                <p class="text-sm text-gray-800"><%= report.reporter_name %> · <%= report.reporter_email %></p>
              </div>
              <div>
                <p class="text-xs font-semibold text-gray-400 uppercase">Alasan</p>
                <p class="text-sm text-gray-800"><%= report.reason %></p>
              </div>
            </div>
            <% if (report.details) { %>
              <div class="mt-3 rounded-lg bg-gray-50 border border-gray-100 p-3">
                <p class="text-xs font-semibold text-gray-400 uppercase mb-1">Detail laporan</p>
                <p class="text-sm text-gray-700 whitespace-pre-line"><%= report.details %></p>
              </div>
            <% } %>
            <% if (report.admin_note) { %>
              <div class="mt-3 rounded-lg bg-indigo-50 border border-indigo-100 p-3">
                <p class="text-xs font-semibold text-indigo-500 uppercase mb-1">Catatan admin</p>
                <p class="text-sm text-indigo-800 whitespace-pre-line"><%= report.admin_note %></p>
              </div>
            <% } %>
          </div>

          <div class="lg:w-72 shrink-0 space-y-2">
            <% if (isJob && report.target_id) { %>
              <a href="/admin/jobs/<%= report.target_id %>/edit" class="block w-full text-center px-3 py-2 rounded-lg border border-gray-300 text-sm font-semibold text-gray-700 hover:bg-gray-50">Lihat Lowongan</a>
            <% } else if (!isJob && report.target_id) { %>
              <a href="/user/<%= report.target_id %>" target="_blank" class="block w-full text-center px-3 py-2 rounded-lg border border-gray-300 text-sm font-semibold text-gray-700 hover:bg-gray-50">Lihat Profil</a>
            <% } %>

            <form action="/admin/reports/<%= report.id %>/action" method="POST" class="space-y-2" onsubmit="return handleConfirm(this, event, 'Lanjutkan tindakan admin untuk laporan ini?');">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <textarea name="admin_note" rows="2" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="Catatan admin (opsional)"></textarea>

              <% if (isJob) { %>
                <button type="submit" name="action" value="suspend_job" class="w-full px-3 py-2 rounded-lg bg-orange-600 text-white text-sm font-semibold hover:bg-orange-700">Suspend Lowongan</button>
                <button type="submit" name="action" value="suspend_user" class="w-full px-3 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold hover:bg-red-700">Ban/Suspend HR</button>
              <% } else { %>
                <button type="submit" name="action" value="suspend_user" class="w-full px-3 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold hover:bg-red-700">Ban/Suspend User</button>
              <% } %>
              <button type="submit" name="action" value="dismiss" class="w-full px-3 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-semibold hover:bg-gray-200">Tolak Laporan</button>
            </form>
          </div>
        </div>
      </div>
      <% }); %>
    <% } else { %>
      <div class="bg-white rounded-xl border border-gray-200 p-10 text-center text-gray-500">
        Belum ada laporan untuk filter ini.
      </div>
    <% } %>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
    <div class="mt-6 flex items-center justify-between">
      <p class="text-sm text-gray-600">Halaman <%= pagination.page %> dari <%= pagination.totalPages %></p>
      <div class="flex gap-2">
        <% if (pagination.hasPrev) { %>
          <a href="?status=<%= selectedStatus %>&page=<%= pagination.page - 1 %>" class="px-3 py-2 border rounded-md bg-white text-sm">Sebelumnya</a>
        <% } %>
        <% if (pagination.hasNext) { %>
          <a href="?status=<%= selectedStatus %>&page=<%= pagination.page + 1 %>" class="px-3 py-2 border rounded-md bg-white text-sm">Berikutnya</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
