<!-- Scroll Animation Script -->
<script>
  // Intersection Observer for scroll animations
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          // Unobserve after animation triggers (run once)
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Add animation classes to elements
    const heroContent = document.querySelector('.home-hero-content');
    if (heroContent) {
      heroContent.classList.add('fade-in-up');
    }

    const statsGrid = document.querySelector('.stats-grid');
    if (statsGrid) {
      statsGrid.classList.add('fade-in-up');
    }

    const featuresSection = document.querySelector('.features-section');
    if (featuresSection) {
      featuresSection.classList.add('fade-in-up');
    }

    // Add staggered animations to feature cards
    const featureCards = document.querySelectorAll('.feature-card');
    featureCards.forEach((card, index) => {
      card.classList.add('fade-in-up', `delay-${(index + 1) * 100}`);
      observer.observe(card);
    });

    // Add animations to job cards
    const jobCards = document.querySelectorAll('.job-card');
    jobCards.forEach((card, index) => {
      card.classList.add('fade-in-up', `delay-${(index % 3 + 1) * 100}`);
      observer.observe(card);
    });

    // Add animation to CTA section
    const ctaSection = document.querySelector('.cta-section');
    if (ctaSection) {
      ctaSection.classList.add('fade-in-up');
      observer.observe(ctaSection);
    }

    // Observe all fade-in-up elements that aren't already observed
    document.querySelectorAll('.fade-in-up').forEach(el => {
      observer.observe(el);
    });

    document.querySelectorAll('.fade-in-left').forEach(el => {
      observer.observe(el);
    });

    document.querySelectorAll('.fade-in-right').forEach(el => {
      observer.observe(el);
    });

    document.querySelectorAll('.scale-in').forEach(el => {
      observer.observe(el);
    });
  });

  // Guest guard: intercept clicks on job-related links for unauthenticated users
  const isLoggedInStr = "<%= typeof isLoggedIn !== 'undefined' && isLoggedIn ? 'true' : 'false' %>";
  const isLoggedIn = isLoggedInStr === "true";
  if (!isLoggedIn) {
    const guestOnlyLinks = document.querySelectorAll('.guest-guard');
    const guestAlert = document.getElementById('guest-alert-modal');

    guestOnlyLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        if (guestAlert) {
          guestAlert.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    // Close modal on button click or backdrop
    if (guestAlert) {
      document.getElementById('guest-alert-close').addEventListener('click', function() {
        guestAlert.classList.add('hidden');
        document.body.style.overflow = '';
      });
      document.getElementById('guest-alert-backdrop').addEventListener('click', function() {
        guestAlert.classList.add('hidden');
        document.body.style.overflow = '';
      });
    }
  }
</script>

<!-- Guest Alert Modal -->
<div id="guest-alert-modal" class="hidden">
  <!-- Backdrop -->
  <div id="guest-alert-backdrop"></div>

  <!-- Modal Card -->
  <div class="guest-alert-card">
    <!-- Close Button -->
    <button id="guest-alert-close" class="guest-alert-close">
      <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Icon -->
    <div class="guest-alert-icon">
      <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24">
