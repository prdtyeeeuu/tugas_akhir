          <a href="/register" class="flex-1 py-3.5 bg-white border-2 border-slate-100 hover:border-brand-200 text-slate-600 text-center font-bold rounded-xl transition-colors">Daftar Gratis</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Intersection Observer for scroll animations
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe animated elements
    document.querySelectorAll('.fade-up, .fade-in-up, .scale-in').forEach(el => {
      observer.observe(el);
    });
  });

  // Guest guard logic
  const isLoggedInStr = "<%= typeof isLoggedIn !== 'undefined' && isLoggedIn ? 'true' : 'false' %>";
  const isLoggedIn = isLoggedInStr === "true";
  
  if (!isLoggedIn) {
    const guestOnlyLinks = document.querySelectorAll('.guest-guard');
    const guestAlert = document.getElementById('guest-alert-modal');

    guestOnlyLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        // Only prevent default if it's not a direct link to login/register
        if (!this.href.includes('/login') && !this.href.includes('/register')) {
          e.preventDefault();
          if (guestAlert) {
            guestAlert.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          }
        }
      });
    });

    // Close modal logic
    const closeModal = () => {
      guestAlert.classList.add('hidden');
      document.body.style.overflow = '';
    };

    if (guestAlert) {
      document.getElementById('guest-alert-close').addEventListener('click', closeModal);
      document.getElementById('guest-alert-backdrop').addEventListener('click', closeModal);
    }
  }
</script>
