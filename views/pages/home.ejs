      </div>
      <% } %>

      <div class="action-buttons">
        <a href="/jobs" class="action-btn primary">Mulai Cari Kerja</a>
        <a href="#features" class="action-btn outline">Pelajari Lebih Lanjut</a>
      </div>

      <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=800&h=450&fit=crop" alt="Tim Profesional Bekerja Sama">
      </div>
    </div>
