<!-- Latest Jobs Section -->
<section class="py-20 sm:py-24 bg-white" id="jobs">
  <div class="max-w-6xl mx-auto px-5 sm:px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div class="fade-up">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">Lowongan Terbaru</h2>
        <p class="mt-3 text-slate-500 text-base max-w-md">Temukan peluang karir terbaik dari perusahaan ternama minggu ini.</p>
      </div>
      <a href="/jobs" class="fade-up inline-flex items-center gap-2 text-brand-600 font-bold hover:gap-3 transition-all">
        Lihat Semua Lowongan
        <span class="iconify" data-icon="lucide:arrow-right"></span>
      </a>
    </div>

    <% if (typeof jobs !== 'undefined' && jobs && jobs.length > 0) { %>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% jobs.slice(0, 6).forEach(function(job) { %>
          <div class="group bg-white border border-slate-200 rounded-2xl p-5 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-100/40 transition-all duration-300 flex flex-col h-full guest-guard" style="cursor:pointer;" onclick="window.location.href='/jobs/<%= job.id %>'">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 rounded-xl border border-slate-100 flex items-center justify-center bg-white overflow-hidden shrink-0">
                <% if (job.company_logo) { %>
                  <img src="/images/companies/<%= job.company_logo %>" alt="<%= job.company %>" class="w-full h-full object-contain">
                <% } else { %>
                  <span class="text-xl font-bold text-brand-600"><%= job.company.charAt(0) %></span>
                <% } %>
              </div>
              <span class="px-2.5 py-1 bg-slate-50 text-slate-500 text-[10px] font-bold rounded-lg uppercase tracking-wider"><%= formatTimeAgo(job.created_at) %></span>
            </div>
            
            <div class="flex-grow">
              <h3 class="text-lg font-bold text-slate-900 group-hover:text-brand-600 transition-colors mb-1 line-clamp-1"><%= job.title %></h3>
              <p class="text-sm text-slate-500 mb-4 flex items-center gap-1.5">
                <span class="iconify" data-icon="lucide:building-2"></span>
                <%= job.company %>
              </p>
              
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-2.5 py-1 bg-brand-50 text-brand-700 text-[11px] font-semibold rounded-lg flex items-center gap-1">
                  <span class="iconify" data-icon="lucide:map-pin"></span>
                  <%= job.location %>
                </span>
                <% if (job.category) { %>
                  <span class="px-2.5 py-1 bg-slate-50 text-slate-600 text-[11px] font-semibold rounded-lg">
                    <%= job.category %>
                  </span>
                <% } %>
              </div>
            </div>

            <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
              <div class="text-slate-900 font-bold text-sm">
                <% if (job.salary_min || job.salary_max) { %>
                  Rp <%= formatSalary(job.salary_min || job.salary_max) %>
                  <% if (job.salary_min && job.salary_max) { %>+<% } %>
                <% } else { %>
                  Kompetitif
                <% } %>
              </div>
              <a href="/jobs/<%= job.id %>" class="text-sm font-bold text-brand-600 hover:text-brand-700">Lamar Cepat</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-12 bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm">
          <span class="iconify text-slate-300 text-3xl" data-icon="lucide:briefcase"></span>
        </div>
        <h3 class="text-lg font-bold text-slate-900">Belum ada lowongan</h3>
        <p class="text-slate-500 text-sm">Silakan cek kembali beberapa saat lagi.</p>
      </div>
    <% } %>
  </div>
</section>

