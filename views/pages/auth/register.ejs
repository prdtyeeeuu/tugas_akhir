<!-- Register Page -->
<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-secondary to-secondary-light py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg">
          <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 16 16">
            <path d="M6.5 14.5v-3a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5ZM6.5 8V6.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5ZM5 5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-5A.5.5 0 0 1 5 5V5Zm.5-3a.5.5 0 0 0-.5.5v2a.5.5 0 0 0 .5.5h5a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 0-.5-.5h-5ZM3 14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12Z"/>
          </svg>
        </div>
      </div>
      <h2 class="text-3xl font-bold text-gray-900">
        Buat Akun Baru
      </h2>
      <p class="mt-2 text-gray-700">
        Bergabung dengan Lokerin dan temukan pekerjaan impianmu
      </p>
    </div>

    <!-- Register Form -->
    <div class="bg-white rounded-2xl shadow-xl p-8">
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-red-600 text-sm"><%= error %></p>
      </div>
      <% } %>

      <form action="/register" method="POST" class="space-y-6">
        
        <!-- Role Selection (New Feature) -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-3">
            Daftar Sebagai
          </label>
          <div class="grid grid-cols-2 gap-4">
            <!-- Job Seeker Option -->
            <label class="role-option cursor-pointer border-2 border-gray-200 rounded-xl p-4 flex flex-col items-center gap-2 hover:border-secondary transition has-[:checked]:border-secondary has-[:checked]:bg-blue-50">
              <input type="radio" name="role" value="job_seeker" class="hidden" checked>
              <svg class="w-8 h-8 text-gray-500 group-has-[:checked]:text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span class="text-sm font-medium text-gray-700">Pencari Kerja</span>
            </label>

            <!-- HR Option -->
            <label class="role-option cursor-pointer border-2 border-gray-200 rounded-xl p-4 flex flex-col items-center gap-2 hover:border-secondary transition has-[:checked]:border-secondary has-[:checked]:bg-blue-50">
              <input type="radio" name="role" value="hr" class="hidden">
              <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              <span class="text-sm font-medium text-gray-700">HR / Perusahaan</span>
            </label>
          </div>
        </div>

        <div class="border-t border-gray-200 my-4"></div>

        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
            Nama Lengkap
          </label>
          <input 
            id="name" 
            name="name" 
            type="text" 
            required 
            value="<%= typeof formData !== 'undefined' && formData ? formData.name || '' : '' %>"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent"
            placeholder="John Doe"
          >
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
            Email
          </label>
          <input 
            id="email" 
            name="email" 
            type="email" 
            required 
            value="<%= typeof formData !== 'undefined' && formData ? formData.email || '' : '' %>"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent"
            placeholder="nama@email.com"
          >
        </div>

        <!-- Password -->
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
            Password
          </label>
          <input 
            id="password" 
            name="password" 
            type="password" 
            required 
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary focus:border-transparent"
            placeholder="Minimal 6 karakter"
          >
        </div>

        <!-- Submit Button -->
        <button 
          type="submit" 
          class="w-full bg-gray-900 hover:bg-gray-800 text-white py-3 rounded-lg font-medium transition"
        >
          Register
        </button>
      </form>

      <!-- Login Link -->
      <div class="mt-6 text-center">
        <p class="text-gray-600">
          Sudah punya akun?
          <a href="/login<%= typeof req !== 'undefined' && req.query && req.query.role ? '?role=' + req.query.role : '' %>" class="text-secondary hover:underline font-medium">
            Login di sini
          </a>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  // Auto-select role based on URL parameter
  document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const role = urlParams.get('role');
    
    if (role === 'hr') {
      const hrRadio = document.querySelector('input[name="role"][value="hr"]');
      if (hrRadio) {
        hrRadio.checked = true;
        // Trigger visual update
        const label = hrRadio.closest('label');
        label.classList.add('border-secondary', 'bg-blue-50');
      }
    }
  });
</script>
