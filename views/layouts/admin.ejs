<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin Panel | Lokerin' %></title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Tailwind Config (Sama seperti main.ejs) -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#FFFFFF',
            secondary: '#ADCEFF',
            'secondary-light': '#C3ADFF',
          },
        },
      },
    }
  </script>

  <!-- Global Fetch CSRF Token Interceptor -->
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <script>
    (function() {
      const origFetch = window.fetch;
      const csrfToken = "<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>";
      window.fetch = async function(...args) {
        let resource = args[0];
        let config = args[1];
        
        if (config && config.method && ['POST', 'PUT', 'PATCH', 'DELETE'].includes(config.method.toUpperCase())) {
          if (!config.headers) {
            config.headers = {};
          }
          if (config.headers instanceof Headers) {
            if (!config.headers.has('x-csrf-token')) config.headers.append('x-csrf-token', csrfToken);
          } else {
            config.headers['x-csrf-token'] = csrfToken;
          }
          args[1] = config;
        }
        return origFetch.apply(window, args);
      };
    })();
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background-color: #f3f4f6; /* Gray-50 untuk kontras dengan konten putih */
      color: #1a1a1a;
    }
    .sidebar {
      width: 250px;
      min-height: 100vh;
      background: white; /* Sama dengan tema utama */
      border-right: 1px solid #e5e7eb;
    }
    .main-content {
      flex: 1;
      height: 100vh;
      overflow-y: auto;
    }
    .nav-item {
      display: flex;
      align-items: center;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      color: #4b5563;
      transition: all 0.2s;
    }
    .nav-item:hover {
      background-color: #ADCEFF; /* Menggunakan secondary color */
      color: #1f2937;
    }
    .nav-item.active {
      background-color: #C3ADFF; /* Menggunakan secondary-light color */
      color: #1f2937;
      font-weight: 600;
    }
    .nav-icon {
      width: 1.25rem;
      height: 1.25rem;
      margin-right: 0.75rem;
    }
  </style>

  <!-- Extracted Styles -->
  <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body class="flex">

  <!-- Sidebar -->
  <aside class="sidebar flex flex-col fixed inset-y-0 left-0 z-50">
    <div class="p-6 border-b border-gray-100 flex items-center justify-between">
      <a href="/" class="flex items-center space-x-2">
        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center shadow-sm">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 16 16">
            <path d="M6.5 14.5v-3a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5ZM6.5 8V6.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5ZM5 5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-5A.5.5 0 0 1 5 5V5Zm.5-3a.5.5 0 0 0-.5.5v2a.5.5 0 0 0 .5.5h5a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 0-.5-.5h-5ZM3 14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12Z"/>
          </svg>
        </div>
        <span class="text-xl font-bold text-gray-800 tracking-tight">Lokerin<span class="text-indigo-600">.</span></span>
      </a>
    </div>

    <div class="flex-1 overflow-y-auto py-4 px-3">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 px-3">Admin Panel</div>
      
      <nav class="space-y-1">
        <a href="/admin/dashboard" class="nav-item <%= typeof active !== 'undefined' && active === 'admin-dashboard' ? 'active' : '' %>">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Dashboard
        </a>
        <a href="/admin/users" class="nav-item <%= typeof active !== 'undefined' && active === 'admin-users' ? 'active' : '' %>">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          Users
        </a>
        <a href="/admin/jobs" class="nav-item <%= typeof active !== 'undefined' && active === 'admin-jobs' ? 'active' : '' %>">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          Jobs
        </a>
        <a href="/admin/images" class="nav-item <%= typeof active !== 'undefined' && active === 'admin-images' ? 'active' : '' %>">
          <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          Images
        </a>
      </nav>
      
      <div class="mt-8">
        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 px-3">Public</div>
        <nav class="space-y-1">
          <a href="/" class="nav-item">
            <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            Kembali ke Lokerin
          </a>
        </nav>
      </div>
    </div>

    <!-- Admin Profile & Logout -->
    <div class="p-4 border-t border-gray-100">
      <% let adminUser = typeof currentUser !== 'undefined' && currentUser ? currentUser : (typeof user !== 'undefined' && user ? user : null); %>
      <% if (adminUser) { %>
        <a href="/profile" class="flex items-center mb-4 px-2 hover:bg-gray-50 p-2 rounded-lg transition-colors cursor-pointer group" title="Kustomisasi Profil Admin">
          <img src="<%= adminUser.profile_image ? '/images/profiles/' + adminUser.profile_image : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(adminUser.name) %>" 
               alt="Admin" class="w-8 h-8 rounded-full border border-gray-200 group-hover:border-indigo-300 transition-colors">
          <div class="ml-3 truncate flex-1">
            <p class="text-sm font-medium text-gray-900 truncate group-hover:text-indigo-600 transition-colors"><%= adminUser.name %></p>
            <p class="text-xs text-gray-500 truncate"><%= adminUser.email %></p>
          </div>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      <% } %>
      <form action="/logout" method="POST" class="w-full">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="w-full flex justify-center items-center px-4 py-2 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors border border-red-100">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
          Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- Main Content Area -->
  <main class="main-content ml-[250px] relative">
    <!-- Optional: Top Header inside main content if needed -->
    <header class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-40 px-8 py-4 flex items-center justify-between">
      <div>
        <!-- Breadcrumb / Header Title bisa diletakkan di sini -->
        <h1 class="text-lg font-semibold text-gray-800"><%= typeof title !== 'undefined' ? title.split('|')[0].trim() : 'Admin Panel' %></h1>
      </div>
      <div>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
          Administrator
        </span>
      </div>
    </header>

    <!-- Page Content -->
    <div class="p-4 sm:p-6 lg:p-8">
      <%- body %>
    </div>
  </main>

  <script src="/js/lokerin-modal.js"></script>
  <!-- Extracted Scripts -->
  <%- typeof script !== 'undefined' ? script : '' %>
  <!-- Custom Popups -->
  <%- include('../partials/custom-popups') %>
</body>
</html>
