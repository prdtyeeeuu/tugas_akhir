<!-- Navbar Component -->
<nav class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <!-- Logo Icon - Purple rounded square with building -->
          <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center shadow-lg">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 16 16">
              <path d="M6.5 14.5v-3a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5v3a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5ZM6.5 8V6.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 .5.5V8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1-.5-.5ZM5 5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-5A.5.5 0 0 1 5 5V5Zm.5-3a.5.5 0 0 0-.5.5v2a.5.5 0 0 0 .5.5h5a.5.5 0 0 0 .5-.5v-2a.5.5 0 0 0-.5-.5h-5ZM3 14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12Z"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-gray-800">Lokerin</span>
        </a>
      </div>

      <!-- Navigation Menu (Desktop) - For logged in users -->
      <%
        let loggedInUser = typeof currentUser !== 'undefined' && currentUser ? currentUser : (typeof user !== 'undefined' && user ? user : null);
        if (loggedInUser) {
      %>
        <div class="hidden md:flex items-center space-x-1">
          <% if (loggedInUser.role === 'admin') { %>
            <!-- Admin Navigation -->
            <a href="/admin/dashboard" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'admin-dashboard' ? 'bg-secondary text-gray-900' : '' %>">
              Dashboard
            </a>
            <a href="/admin/users" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'admin-users' ? 'bg-secondary text-gray-900' : '' %>">
              Users
            </a>
            <a href="/admin/jobs" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'admin-jobs' ? 'bg-secondary text-gray-900' : '' %>">
              Jobs
            </a>
            <a href="/admin/images" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'admin-images' ? 'bg-secondary text-gray-900' : '' %>">
              Images
            </a>
          <% } else if (loggedInUser.role === 'hr') { %>
            <!-- HR Navigation -->
            <a href="/hr/dashboard" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'hr-dashboard' ? 'bg-secondary text-gray-900' : '' %>">
              Dashboard
            </a>
            <a href="/hr/jobs" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'hr-jobs' ? 'bg-secondary text-gray-900' : '' %>">
              Kelola Lowongan
            </a>
            <a href="/hr/interviews" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition flex items-center gap-1.5 <%= typeof active !== 'undefined' && active === 'hr-interviews' ? 'bg-secondary text-gray-900' : '' %>">
              <svg width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/>
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
              </svg>
              Interview
            </a>
          <% } else { %>
            <!-- Job Seeker Navigation -->
            <a href="/dashboard" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'dashboard' ? 'bg-secondary text-gray-900' : '' %>">
              Dashboard
            </a>
            <a href="/jobs" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'jobs' ? 'bg-secondary text-gray-900' : '' %>">
              Find Jobs
            </a>
            <a href="/applications" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'applications' ? 'bg-secondary text-gray-900' : '' %>">
              Lamaran Saya
            </a>
          <% } %>

          <a href="/chat" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'chat' ? 'bg-secondary text-gray-900' : '' %> flex items-center gap-2">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
              <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4.414a1 1 0 0 0-.707.293L.854 15.146A.5.5 0 0 1 0 14.793V2zm5 4a1 1 0 1 0-2 0 1 1 0 0 0 2 0zm4 0a1 1 0 1 0-2 0 1 1 0 0 0 2 0zm3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
            </svg>
            Pesan
            <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
            <span class="unread-badge-nav"><%= unreadCount %></span>
            <% } %>
          </a>

          <a href="/profile" class="px-4 py-2 rounded-lg text-gray-700 hover:bg-secondary hover:text-gray-900 transition <%= typeof active !== 'undefined' && active === 'profile' ? 'bg-secondary text-gray-900' : '' %>">
            Profile
          </a>
        </div>

        <!-- Right Side - Logged In -->
        <div class="flex items-center space-x-3">
          <!-- User Name Badge -->
          <a href="/profile" title="Lihat Profil Saya" class="hidden sm:flex items-center gap-2 pl-2 pr-4 py-1.5 bg-gray-50 border border-gray-200 rounded-full text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-100 transition-colors cursor-pointer">
            <img src="<%= loggedInUser.profile_image ? '/images/profiles/' + loggedInUser.profile_image + '?t=' + Date.now() : 'https://ui-avatars.com/api/?name=' + encodeURIComponent(loggedInUser.name) + '&background=f3f4f6&color=4b5563&size=100' %>" 
                 alt="Profile" 
                 class="w-7 h-7 rounded-full object-cover border border-gray-200 bg-white">
            <div class="flex flex-col">
              <span class="leading-none"><%= loggedInUser.name %></span>
              <span class="text-[10px] font-bold tracking-wide <%= loggedInUser.role === 'admin' ? 'text-purple-600' : loggedInUser.role === 'hr' ? 'text-indigo-600' : 'text-blue-500' %> uppercase mt-0.5">
                <%= loggedInUser.role === 'admin' ? 'Administrator' : loggedInUser.role === 'hr' ? 'Recruiter' : 'Job Seeker' %>
              </span>
            </div>
          </a>

          <!-- Logout Button -->
          <form action="/logout" method="POST" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' && csrfToken ? csrfToken : '' %>">
            <button type="submit" class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg transition text-sm font-medium cursor-pointer">
              Logout
            </button>
          </form>
        </div>
      <% } else { %>
        <!-- Navigation Menu (Desktop) - For public/guest users -->
        <div class="hidden md:flex items-center"></div>

        <!-- Right Side - Not Logged In -->
        <div class="flex items-center space-x-3">
          <a href="/login" class="px-4 py-2 border border-blue-600 text-blue-600 hover:bg-blue-50 rounded-lg transition text-sm font-medium">
            Masuk
          </a>
          <a href="/register" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition text-sm font-medium">
            Daftar Sekarang
          </a>
        </div>
      <% } %>
    </div>
  </div>
</nav>

<!-- Mobile Menu Toggle (for future enhancement) -->
<script>
  // Mobile menu functionality can be added here
</script>
