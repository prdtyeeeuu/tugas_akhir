# ==========================================
# LOKERIN - Environment Configuration
# ==========================================
# Copy file ini ke .env dan sesuaikan nilainya

# Server Configuration
PORT=3000
NODE_ENV=development

# Session Secret (ganti dengan random string yang panjang)
SESSION_SECRET=lokerin-session-secret-change-this-in-production

# JWT Secret (ganti dengan random string yang panjang)
JWT_SECRET=lokerin-jwt-secret-change-this-in-production

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=locker_db
