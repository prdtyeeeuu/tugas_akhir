# ==========================================
# LOKERIN - Environment Configuration
# ==========================================
# Copy file ini ke .env dan sesuaikan nilainya

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Secrets (IMPORTANT: Use long random strings in production!)
SESSION_SECRET=change-this-to-a-long-random-string-in-production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=locker_db
